@model NewSchool.Web.Models.FamilyLibraryHomeViewModel
@{
    ViewData["Title"] = "Biblioteca";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var hasCurrentBook = Model.CurrentBook is not null;
    var primaryBookActionUrl = hasCurrentBook
        ? (Model.SelectedChildId.HasValue
            ? Url.Action("Book", "Library", new { id = Model.CurrentBook!.Id, childId = Model.SelectedChildId })
            : Url.Action("Book", "Library", new { id = Model.CurrentBook!.Id }))
        : Model.SpotlightBook?.AccessUrl;
    var primaryBookActionLabel = hasCurrentBook ? "Continuar leitura" : "Abrir livro";
    var primaryBookHeadline = hasCurrentBook ? "Continuar leitura" : "Livro de agora";
    var primaryBookStatus = hasCurrentBook
        ? $"Página {Model.CurrentBook!.CurrentPageNumber} de {Model.CurrentBook.PageCount}"
        : Model.SpotlightBook?.ProgressLabel;
    var hasMoreLibrarySections =
        Model.WeeklyReading is not null ||
        Model.SystemCurriculumTracks.Count > 0 ||
        Model.CurriculumShelves.Count > 0 ||
        (Model.AnnualReadingSpine is not null && Model.AnnualReadingSpine.Phases.Count > 0);
}

<section class="family-library-shell">
    <div class="child-topbar-row">
        @if (Model.SelectedChildId.HasValue)
        {
            <a class="back-inline-link" asp-controller="Parent" asp-action="Child" asp-route-id="@Model.SelectedChildId">Voltar para hoje</a>
        }
        else
        {
            <a class="back-inline-link" asp-controller="Parent" asp-action="Index">Voltar para hoje</a>
        }
        <div class="hero-action-row">
            @if (Model.SelectedChildId.HasValue)
            {
                <a class="btn-secondary" asp-controller="Library" asp-action="Printables" asp-route-childId="@Model.SelectedChildId">Imprimíveis</a>
            }
            else
            {
                <a class="btn-secondary" asp-controller="Library" asp-action="Printables">Imprimíveis</a>
            }
        </div>
    </div>

    @if (Model.CurrentBook is not null || Model.SpotlightBook is not null)
    {
        <section class="family-library-section">
            <article class="family-library-current-book">
                <div>
                    <span class="app-kicker">Biblioteca</span>
                    <h1>@(Model.CurrentBook?.Title ?? Model.SpotlightBook!.Title)</h1>
                    <div class="family-library-book-meta">
                        <span>@(Model.CurrentBook?.Category ?? Model.SpotlightBook!.Category)</span>
                        <span>@(Model.CurrentBook?.EducationStage ?? Model.SpotlightBook!.EducationStage)</span>
                        @if (!string.IsNullOrWhiteSpace(primaryBookStatus))
                        {
                            <span>@primaryBookStatus</span>
                        }
                    </div>
                </div>
                <div class="hero-action-row">
                    <a class="btn-primary" href="@primaryBookActionUrl">@primaryBookActionLabel</a>
                    @if (Model.SpotlightPrintable is not null)
                    {
                        <a class="btn-secondary" href="@Model.SpotlightPrintable.AccessUrl">Abrir imprimível</a>
                    }
                </div>
            </article>

            @if (Model.SpotlightPrintable is not null)
            {
                <p class="small-meta">
                    Se depois da leitura precisar de papel, o imprimível desta fase já está separado em <strong>@Model.SpotlightPrintable.Title</strong>.
                </p>
            }
        </section>
    }

    @if (hasMoreLibrarySections)
    {
        <details class="family-library-section family-library-collapsible">
            <summary class="family-library-collapsible-summary">
                <div>
                    <span class="app-kicker">Ver mais</span>
                    <h2>Leitura da semana, currículo e coleções</h2>
                </div>
                <span class="app-status neutral">Opcional</span>
            </summary>

            @if (Model.WeeklyReading is not null)
            {
                <section class="family-library-section nested-surface">
                    <div class="family-library-section-heading">
                        <div>
                            <span class="app-kicker">Leitura da semana</span>
                            <h2>@Model.WeeklyReading.Headline</h2>
                        </div>
                        <span class="app-status success">@Model.WeeklyReading.PhaseLabel</span>
                    </div>

                    <div class="family-highlight-grid family-highlight-grid-simple">
                        <article class="overview-card">
                            <span class="app-kicker">Meta</span>
                            <h2>Leitura guiada</h2>
                            <p>@Model.WeeklyReading.WeeklyGoal</p>
                        </article>

                        <article class="overview-card">
                            <span class="app-kicker">Como conduzir</span>
                            <h2>Passos curtos</h2>
                            <p>@Model.WeeklyReading.ParentGuide</p>
                        </article>

                        <article class="overview-card">
                            <span class="app-kicker">Fechamento</span>
                            <h2>@Model.WeeklyReading.MonthlyGoal.ProgressLabel</h2>
                            <p>@Model.WeeklyReading.CompletionSignal</p>
                        </article>
                    </div>

                    <div class="guided-lesson-meta-grid">
                        @if (Model.WeeklyReading.Book is not null)
                        {
                            <article class="child-card-note nested-surface">
                                <strong>Livro da semana</strong>
                                <p><strong>@Model.WeeklyReading.Book.Title</strong></p>
                                <p>@Model.WeeklyReading.Book.FitReason</p>
                                <a class="btn-primary" href="@Model.WeeklyReading.Book.AccessUrl">@Model.WeeklyReading.Book.AccessLabel</a>
                            </article>
                        }

                        @if (Model.WeeklyReading.Printable is not null)
                        {
                            <article class="child-card-note nested-surface">
                                <strong>Atividade de papel</strong>
                                <p><strong>@Model.WeeklyReading.Printable.Title</strong></p>
                                <p>@Model.WeeklyReading.Printable.FitReason</p>
                                <a class="btn-secondary" href="@Model.WeeklyReading.Printable.AccessUrl">@Model.WeeklyReading.Printable.AccessLabel</a>
                            </article>
                        }
                    </div>

                    @if (Model.WeeklyReading.Book is not null && Model.SelectedChildId.HasValue && Model.WeeklyReading.MaterialId.HasValue)
                    {
                        if (Model.WeeklyReading.IsCompleted)
                        {
                            <div class="lesson-complete-chip">
                                <strong>Leitura da semana já registrada.</strong>
                                <span>@Model.WeeklyReading.Book.Title entrou no histórico pedagógico da criança.</span>
                            </div>
                        }
                        else
                        {
                            <form method="post" asp-controller="Library" asp-action="MarkWeeklyReadingComplete" class="guided-complete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="childId" value="@Model.SelectedChildId" />
                                <input type="hidden" name="materialId" value="@Model.WeeklyReading.MaterialId" />
                                <input type="hidden" name="phaseNumber" value="@Model.WeeklyReading.PhaseNumber" />
                                <input type="hidden" name="periodKey" value="@Model.WeeklyReading.PeriodKey" />
                                <input type="hidden" name="weekNumber" value="@Model.WeeklyReading.WeekNumber" />
                                <input type="hidden" name="phaseLabel" value="@Model.WeeklyReading.PhaseLabel" />
                                <input type="hidden" name="goalLabel" value="@Model.WeeklyReading.WeeklyGoal" />
                                <input type="hidden" name="returnUrl" value="@currentUrl" />
                                <button class="btn-primary" type="submit">@Model.WeeklyReading.CompletionActionLabel</button>
                            </form>
                        }
                    }
                </section>
            }

            @if (Model.SystemCurriculumTracks.Count > 0)
            {
                <section class="family-library-section nested-surface">
                    <div class="family-library-section-heading">
                        <div>
                            <span class="app-kicker">Currículo desta fase</span>
                            <h2>As matérias já mostram a unidade certa de agora</h2>
                        </div>
                        <span class="app-status neutral">@Model.SystemCurriculumTracks.Count matéria(s)</span>
                    </div>

                    <div class="curriculum-subject-grid">
                        @foreach (var track in Model.SystemCurriculumTracks)
                        {
                            <article class="curriculum-subject-card">
                                <div class="child-dashboard-top">
                                    <div>
                                        <h3>@track.Title</h3>
                                        <p>@track.AgeBandLabel • @track.CurrentPhaseLabel</p>
                                    </div>
                                    <span class="app-status @track.DomainChipClass">@track.DomainLabel</span>
                                </div>

                                @if (track.CurrentUnit is not null)
                                {
                                    <article class="child-card-note">
                                        <strong>@track.CurrentUnit.UnitLabel • @track.CurrentUnit.Title</strong>
                                        <p>@track.CurrentUnit.Summary</p>
                                    </article>

                                    <div class="guided-lesson-meta-grid">
                                        <article class="child-card-note nested-surface">
                                            <strong>Tarefa principal</strong>
                                            <p>@track.CurrentUnit.TaskPrompt</p>
                                        </article>

                                        <article class="child-card-note nested-surface">
                                            <strong>Quando seguir</strong>
                                            <p>@track.CurrentUnit.CompletionSignal</p>
                                        </article>
                                    </div>
                                }

                                @if (track.PhaseSequences.Count > 0)
                                {
                                    <details class="micro-sequence-details">
                                        <summary>Ver sequência do ano</summary>
                                        <div class="phase-sequence-list">
                                            @foreach (var phase in track.PhaseSequences)
                                            {
                                                <article class="phase-sequence-item @(phase.IsCurrent ? "is-current" : string.Empty)">
                                                    <div class="section-heading-row compact">
                                                        <strong>@phase.PhaseLabel</strong>
                                                        <span class="app-status @(phase.IsCurrent ? "success" : "neutral")">
                                                            @(phase.IsCurrent ? "agora" : "depois")
                                                        </span>
                                                    </div>
                                                    <p>@phase.Summary</p>
                                                </article>
                                            }
                                        </div>
                                    </details>
                                }
                            </article>
                        }
                    </div>
                </section>
            }

            @if (Model.CurriculumShelves.Count > 0)
            {
                <section class="family-library-section nested-surface">
                    <div class="family-library-section-heading">
                        <div>
                            <span class="app-kicker">Coleções por matéria</span>
                            <h2>Abra o acervo organizado pelo currículo</h2>
                        </div>
                        <span class="app-status neutral">@Model.CurriculumShelves.Count coleção(ões)</span>
                    </div>

                    <div class="lesson-collapsible-list">
                        @foreach (var shelf in Model.CurriculumShelves)
                        {
                            <details class="lesson-collapsible">
                                <summary>
                                    <div>
                                        <strong>@shelf.Title</strong>
                                        <p>@shelf.Summary</p>
                                    </div>
                                    <span class="app-status neutral">@shelf.Items.Count item(ns)</span>
                                </summary>

                                <div class="lesson-collapsible-body">
                                    <div class="family-library-book-grid">
                                        @foreach (var item in shelf.Items.Take(6))
                                        {
                                            <article class="family-library-book-card">
                                                <div class="family-library-book-copy">
                                                    <div class="family-library-book-topline">
                                                        <span class="family-library-chip">@(item.IsPrintable ? "Atividade" : "Livro")</span>
                                                        <span class="family-library-status @(item.IsCompleted ? "complete" : item.IsStarted ? "reading" : "new")">@item.ProgressLabel</span>
                                                    </div>
                                                    <h3>@item.Title</h3>
                                                    <p>@item.Description</p>
                                                    <div class="family-library-book-meta">
                                                        <span>@item.Category</span>
                                                        <span>@item.EducationStage</span>
                                                    </div>
                                                    <div class="family-library-progress-note">@item.FitReason</div>
                                                </div>
                                                <div class="family-library-book-actions">
                                                    <span class="family-library-age-note">@item.AgeLabel</span>
                                                    <a class="btn-primary" href="@item.AccessUrl">@item.AccessLabel</a>
                                                </div>
                                            </article>
                                        }
                                    </div>

                                    <div class="hero-action-row">
                                        <a class="btn-secondary" href="@shelf.ActionUrl">@shelf.ActionLabel</a>
                                    </div>
                                </div>
                            </details>
                        }
                    </div>
                </section>
            }

            @if (Model.AnnualReadingSpine is not null && Model.AnnualReadingSpine.Phases.Count > 0)
            {
                <section class="family-library-section nested-surface">
                    <div class="family-library-section-heading">
                        <div>
                            <span class="app-kicker">Literatura do ano</span>
                            <h2>@Model.AnnualReadingSpine.Headline</h2>
                        </div>
                        <span class="app-status success">@Model.AnnualReadingSpine.CurrentPhaseLabel</span>
                    </div>

                    <div class="lesson-collapsible-list">
                        @foreach (var phase in Model.AnnualReadingSpine.Phases)
                        {
                            <details class="lesson-collapsible" @(phase.IsCurrent ? "open" : null)>
                                <summary>
                                    <div>
                                        <strong>@phase.PhaseLabel • @phase.Title</strong>
                                        <p>@phase.Summary</p>
                                    </div>
                                    <span class="app-status @(phase.IsCurrent ? "success" : "neutral")">
                                        @(phase.IsCurrent ? "agora" : "depois")
                                    </span>
                                </summary>

                                <div class="lesson-collapsible-body">
                                    <p><strong>Ritmo:</strong> @phase.WeeklyRhythm</p>
                                    <p><strong>Como conduzir:</strong> @phase.ParentGuide</p>
                                    <p><strong>Sinal de avanço:</strong> @phase.CompletionSignal</p>
                                </div>
                            </details>
                        }
                    </div>
                </section>
            }
        </details>
    }

    <details class="family-library-section family-library-collapsible">
        <summary class="family-library-collapsible-summary">
            <div>
                <span class="app-kicker">Acervo completo</span>
                <h2>Buscar livros sem poluir a primeira tela</h2>
            </div>
            <span class="app-status neutral">@Model.Books.Count de @Model.TotalBooks</span>
        </summary>

        <form method="get" class="family-library-tools">
            @if (Model.SelectedChildId.HasValue)
            {
                <input type="hidden" name="childId" value="@Model.SelectedChildId" />
            }

            <div class="family-library-search-panel">
                <label for="library-search">Buscar livro por nome</label>
                <input id="library-search" class="input family-library-search-input" type="search" name="q" value="@Model.SearchTerm" placeholder="Digite o nome do livro" />
            </div>

            <div class="family-library-filter-grid">
                <div>
                    <label for="collection">Coleção</label>
                    <select id="collection" name="collection" class="input">
                        <option value="">Todas as coleções</option>
                        @foreach (var filter in Model.CollectionFilters)
                        {
                            if (string.Equals(Model.SelectedCollection, filter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@filter" selected>@filter</option>
                            }
                            else
                            {
                                <option value="@filter">@filter</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label for="stage">Etapa</label>
                    <select id="stage" name="stage" class="input">
                        <option value="">Todas as etapas</option>
                        @foreach (var filter in Model.StageFilters)
                        {
                            if (string.Equals(Model.SelectedStage, filter, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@filter" selected>@filter</option>
                            }
                            else
                            {
                                <option value="@filter">@filter</option>
                            }
                        }
                    </select>
                </div>

                @if (Model.AgeFilters.Count > 0)
                {
                    <div>
                        <label for="age">Idade / ano</label>
                        <select id="age" name="age" class="input">
                            <option value="">Todas as faixas</option>
                            @foreach (var filter in Model.AgeFilters)
                            {
                                if (string.Equals(Model.SelectedAgeFilter, filter, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@filter" selected>@filter</option>
                                }
                                else
                                {
                                    <option value="@filter">@filter</option>
                                }
                            }
                        </select>
                    </div>
                }
            </div>

            <div class="family-library-tools-footer">
                <p>@Model.Books.Count de @Model.TotalBooks livros encontrados.</p>
                <div class="family-library-hero-actions">
                    <button class="btn-primary" type="submit">Aplicar filtros</button>
                    @if (Model.SelectedChildId.HasValue)
                    {
                        <a class="btn-secondary" asp-controller="Library" asp-action="Index" asp-route-childId="@Model.SelectedChildId">Limpar filtros</a>
                    }
                    else
                    {
                        <a class="btn-secondary" asp-controller="Library" asp-action="Index">Limpar filtros</a>
                    }
                </div>
            </div>
        </form>

        @if (Model.Books.Count == 0)
        {
            <section class="panel">
                <span class="app-kicker">Sem resultados</span>
                <h2>Nenhum livro combina com os filtros</h2>
                <p>Tente outra busca ou limpe os filtros para voltar ao acervo completo.</p>
            </section>
        }
        else
        {
            <div class="family-library-book-grid">
                @foreach (var book in Model.Books)
                {
                    <partial name="_BookCard" model="book" />
                }
            </div>
        }
    </details>

    @if (Model.FavoriteItems.Count > 0)
    {
        <details class="family-library-section family-library-collapsible">
            <summary class="family-library-collapsible-summary">
                <div>
                    <span class="app-kicker">Favoritos</span>
                    <h2>Materiais guardados para voltar depois</h2>
                </div>
                <span class="app-status neutral">@Model.FavoriteItems.Count</span>
            </summary>
            <div class="family-library-book-grid">
                @foreach (var book in Model.FavoriteItems)
                {
                    <partial name="_BookCard" model="book" />
                }
            </div>
        </details>
    }

    @if (Model.CompletedItems.Count > 0)
    {
        <details class="family-library-section family-library-collapsible">
            <summary class="family-library-collapsible-summary">
                <div>
                    <span class="app-kicker">Concluídos</span>
                    <h2>Livros lidos até o fim</h2>
                </div>
                <span class="app-status neutral">@Model.CompletedItems.Count</span>
            </summary>
            <div class="family-library-book-grid">
                @foreach (var book in Model.CompletedItems)
                {
                    <partial name="_BookCard" model="book" />
                }
            </div>
        </details>
    }
</section>
