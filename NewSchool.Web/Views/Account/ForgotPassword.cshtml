@model NewSchool.Web.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Esqueci minha senha";
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="eyebrow">NewSchool</div>
        <h1>Recupere o acesso da familia</h1>
        <p class="muted">Digite o email da conta. Se ele existir no sistema, nos enviamos um link de redefinicao.</p>

        <form method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <label asp-for="Email"></label>
            <input asp-for="Email" class="input" placeholder="familia@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="alert-soft success">@Model.StatusMessage</div>
            }

            <button type="submit" class="btn-primary">Enviar link de redefinicao</button>
        </form>

        <p class="muted"><a asp-action="Login">Voltar para entrar</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
