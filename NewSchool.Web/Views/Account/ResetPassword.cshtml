@model NewSchool.Web.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Redefinir senha";
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="eyebrow">NewSchool</div>
        <h1>Crie uma nova senha</h1>
        <p class="muted">Use uma senha nova para voltar ao painel da familia com seguranca.</p>

        <form method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <label asp-for="Password"></label>
            <input asp-for="Password" class="input" />
            <span asp-validation-for="Password" class="text-danger"></span>

            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" class="input" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert-soft danger">@Model.ErrorMessage</div>
            }

            <button type="submit" class="btn-primary">Salvar nova senha</button>
        </form>

        <p class="muted"><a asp-action="Login">Voltar para entrar</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
