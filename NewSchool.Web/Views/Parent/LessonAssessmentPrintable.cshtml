@model NewSchool.Web.Models.FundamentalAssessmentPrintableViewModel
@{
    ViewData["Title"] = Model.AssessmentTitle;
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" href="@Model.ChildUrl">Voltar para hoje</a>
        <span class="app-status neutral">Teste da matéria</span>
    </div>

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">@Model.SchoolPlacementLabel</span>
                <h1>@Model.AssessmentTitle</h1>
                <p>@Model.PrintableSummary</p>
            </div>
            <span class="app-status neutral">@Model.QuestionCount pergunta(s)</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">@Model.SubjectLabel</span>
                <h2>@Model.LessonTitle</h2>
                <p>@Model.UnitTitle</p>
            </div>

            <div class="hero-action-row">
                <button class="btn-primary" type="button" onclick="window.print()">Imprimir teste</button>
                <a class="btn-secondary" href="@Model.CorrectionUrl">Corrigir</a>
            </div>
        </article>
    </section>

    <article class="child-card-note">
        <strong>Como usar</strong>
        <p>Aplique este teste no papel depois da aula. Depois volte em <strong>Corrigir</strong> para marcar cada item como acertou ou errou e salvar a nota.</p>
    </article>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Perguntas</span>
                <h2>@Model.PrintableHeadline</h2>
            </div>
        </div>

        <div class="simple-steps-list">
            @foreach (var question in Model.Questions)
            {
                <article class="simple-step-item">
                    <strong>@question.SortOrder. @question.Prompt</strong>
                    <div class="assessment-answer-space"></div>
                </article>
            }
        </div>
    </section>
</section>
