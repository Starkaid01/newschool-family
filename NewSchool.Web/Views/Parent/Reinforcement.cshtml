@model NewSchool.Web.Models.ChildReinforcementViewModel
@{
    ViewData["Title"] = "Reforço";
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" href="@Model.ChildUrl">Voltar para hoje</a>
        <span class="app-status neutral">Reforço</span>
    </div>

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">@Model.SchoolPlacementLabel</span>
                <h1>@Model.Headline</h1>
                <p>@Model.Summary</p>
            </div>
            <span class="app-status neutral">@Model.Subjects.Count matéria(s)</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">Leitura das notas</span>
                <h2>@Model.ChildName</h2>
                <p>Use esta tela para descobrir quais matérias precisam de retomada antes de seguir no mesmo ritmo.</p>
            </div>

            <div class="hero-action-row">
                <a class="btn-secondary" href="@Model.SchoolReportUrl">Abrir relatório</a>
            </div>
        </article>
    </section>

    @if (Model.Subjects.Count == 0)
    {
        <section class="app-card">
            <p>Nenhuma matéria está pedindo reforço agora. Continue acompanhando as próximas correções.</p>
        </section>
    }
    else
    {
        <section class="app-card">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Matérias em atenção</span>
                    <h2>Onde retomar antes</h2>
                </div>
            </div>

            <div class="curriculum-subject-grid">
                @foreach (var subject in Model.Subjects)
                {
                    <article class="curriculum-subject-card">
                        <div class="child-dashboard-top">
                            <div>
                                <h3>@subject.SubjectLabel</h3>
                                <p>@subject.AssessmentCount teste(s) corrigido(s)</p>
                            </div>
                            <span class="app-status @subject.SubjectChipClass">@subject.AverageScoreLabel</span>
                        </div>

                        <article class="child-card-note">
                            <strong>Por que reforçar</strong>
                            <p>@subject.ReinforcementSummary</p>
                        </article>

                        <article class="child-card-note nested-surface">
                            <strong>Próximo passo</strong>
                            <p>@subject.NextAction</p>
                        </article>
                    </article>
                }
            </div>
        </section>
    }
</section>
