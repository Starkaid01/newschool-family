@using System.Linq
@model NewSchool.Web.Models.ParentDashboardViewModel
@{
    ViewData["Title"] = "Hoje";
    var nextChild = Model.Children.FirstOrDefault(child => !child.PlanCompletedToday) ?? Model.Children.FirstOrDefault();
    var hasMultipleChildren = Model.Children.Count > 1;
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusKind = TempData["StatusKind"]?.ToString();
}

@Html.AntiForgeryToken()

<section class="family-app-shell family-app-shell-simple">
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <section class="app-inline-message @(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "warning" : string.Empty)">
            <strong>@(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "Atenção." : "Tudo certo.")</strong>
            <span>@statusMessage</span>
        </section>
    }

    @if ((string?)ViewBag.Checkout == "success")
    {
        <section class="app-inline-message">
            <strong>Pagamento confirmado.</strong>
            <span>O limite do acervo da família está sendo atualizado.</span>
        </section>
    }
    else if ((string?)ViewBag.Checkout == "cancel")
    {
        <section class="app-inline-message warning">
            <strong>Checkout cancelado.</strong>
            <span>O sistema continua livre. O upgrade só serve para ampliar o acervo de fotos, vídeos e documentos.</span>
        </section>
    }

    <section class="child-hero-card child-hero-card-simple dashboard-hero-compact">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">Hoje</span>
                <h1>
                    @if (Model.Children.Count == 0)
                    {
                        @:Comece cadastrando a primeira criança.
                    }
                    else if (hasMultipleChildren)
                    {
                        @:Escolha quem vai estudar agora.
                    }
                    else
                    {
                        @:Abra a lição de @(nextChild?.FullName ?? "sua criança") e siga sem montar nada.
                    }
                </h1>
                <p>
                    @if (Model.Children.Count == 0)
                    {
                        @:Assim que a primeira criança entrar, o sistema já monta aula do dia, currículo, biblioteca e evidências no lugar certo.
                    }
                    else if (hasMultipleChildren)
                    {
                        @:Cada criança abaixo já abre na lição certa. O pai só precisa tocar em Abrir hoje na criança que ainda falta estudar.
                    }
                    else
                    {
                        @:O sistema já deixou a próxima lição pronta. Conclua uma por vez e guarde evidências só quando realmente fizer sentido.
                    }
                </p>
            </div>
            <span class="app-status neutral">@Model.TotalChildren criança(s)</span>
        </div>

        <div class="hero-action-row">
            @if (Model.Children.Count == 0)
            {
                <a class="btn-primary" asp-action="CreateChild">Cadastrar criança</a>
                <a class="btn-secondary" asp-action="Plans">Ver planos</a>
            }
            else if (hasMultipleChildren)
            {
                <a class="btn-primary" href="#children-section">Ver crianças</a>
                <a class="btn-secondary" asp-action="EvidenceHome">Abrir evidências</a>
            }
            else if (nextChild is not null)
            {
                <a class="btn-primary" asp-action="Child" asp-route-id="@nextChild.Id">Abrir hoje</a>
                <a class="btn-secondary" asp-action="Curriculum" asp-route-id="@nextChild.Id">Ver currículo</a>
            }
        </div>
    </section>

    @if (Model.Children.Count == 0)
    {
        <section class="family-empty-state">
            <article class="app-card">
                <span class="app-kicker">Primeiro passo</span>
                <h2>Cadastre a primeira criança</h2>
                <p>O sistema cria a aula do dia, o currículo anual, a biblioteca guiada e o acervo inicial assim que a criança entra.</p>
                <div class="hero-action-row">
                    <a class="btn-primary" asp-action="CreateChild">Cadastrar criança</a>
                    <a class="btn-secondary" asp-action="Plans">Ver planos do acervo</a>
                </div>
            </article>
        </section>
    }
    else
    {
        <section class="child-strip-section" id="children-section">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Crianças</span>
                    <h2>Quem vai estudar agora</h2>
                </div>
                <a class="btn-secondary" asp-action="CreateChild">Adicionar criança</a>
            </div>

            <div class="child-strip-grid">
                @foreach (var child in Model.Children)
                {
                    var childInitial = string.IsNullOrWhiteSpace(child.FullName)
                        ? "C"
                        : child.FullName.Trim()[0].ToString().ToUpperInvariant();

                    <article class="mini-child-card mini-child-card-actionable">
                        <span class="mini-child-avatar">@childInitial</span>
                        <div>
                            <strong>@child.FullName</strong>
                            <span>@child.SchoolPlacementLabel • @child.DailyStudyMinutes min/dia</span>
                            <span>Hoje: @(child.PlanCompletedToday ? "dia concluído" : child.CurrentFocus)</span>
                        </div>
                        <span class="app-status @(child.PlanCompletedToday ? "success" : "warning")">
                            @(child.PlanCompletedToday ? "feito hoje" : child.IsPreparingTodayPlan ? "preparando" : "pronto agora")
                        </span>
                        <div class="mini-child-actions">
                            <a class="btn-primary" asp-action="Child" asp-route-id="@child.Id">@(child.PlanCompletedToday ? "Revisar hoje" : "Abrir hoje")</a>
                            <a class="btn-secondary" asp-action="Curriculum" asp-route-id="@child.Id">Currículo</a>
                            <details class="mini-child-more">
                                <summary>Mais</summary>
                                <div class="mini-child-more-body">
                                    <a class="btn-secondary" asp-controller="Library" asp-action="Index" asp-route-childId="@child.Id">Biblioteca</a>
                                    <a class="btn-secondary" asp-action="Evidences" asp-route-id="@child.Id">Evidências</a>
                                    <a class="btn-secondary" asp-action="EditChild" asp-route-id="@child.Id">Editar</a>
                                    <form method="post"
                                          asp-action="DeleteChild"
                                          asp-route-id="@child.Id"
                                          class="inline-action-form"
                                          onsubmit="return confirm('Tem certeza que deseja excluir esta criança e todo o histórico dela?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn-danger" type="submit">Excluir</button>
                                    </form>
                                </div>
                            </details>
                        </div>
                    </article>
                }
            </div>
        </section>

        <details class="micro-sequence-details dashboard-guide-details">
            <summary>Ver como usar o sistema sem se perder</summary>
            <div class="simple-steps-list compact">
                <article class="simple-step-item">
                    <strong>1. Hoje</strong>
                    <p>Toque em <strong>Abrir hoje</strong> na criança certa. O sistema já deixa a lição atual na ordem correta.</p>
                </article>
                <article class="simple-step-item">
                    <strong>2. Currículo</strong>
                    <p>Abra só quando quiser entender a unidade atual, a prova da etapa e o que vem depois.</p>
                </article>
                <article class="simple-step-item">
                    <strong>3. Biblioteca</strong>
                    <p>Use quando precisar de leitura, apostila ou folha para imprimir ligada à fase da criança.</p>
                </article>
                <article class="simple-step-item">
                    <strong>4. Evidências</strong>
                    <p>Guarde foto, vídeo ou documento depois da lição, sem misturar isso com a rotina de ensinar.</p>
                </article>
            </div>
        </details>
    }
</section>
