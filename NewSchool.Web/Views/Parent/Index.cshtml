@using System.Linq
@model NewSchool.Web.Models.ParentDashboardViewModel
@{
    ViewData["Title"] = "Painel";
    var nextChild = Model.Children.FirstOrDefault(child => !child.PlanCompletedToday) ?? Model.Children.FirstOrDefault();
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusKind = TempData["StatusKind"]?.ToString();
    var billingState = ViewBag.Billing?.ToString();
    var returnUrl = Url.Action("Index", "Parent") ?? "/Parent/Index";
}

@Html.AntiForgeryToken()

<section class="family-app-shell family-app-shell-simple">
    <section class="family-hero-card family-hero-card-simple">
        <div class="family-hero-copy">
            <span class="app-kicker">Painel da família</span>
            <h1>@Model.ParentName, tudo pronto para ensinar hoje.</h1>
            <p>Abra uma criança, siga as lições em ordem e marque concluído. O currículo inteiro continua livre. A cobrança entra só quando a família quer guardar mais fotos, vídeos e documentos no acervo.</p>
            <div class="hero-chip-row">
                <span class="app-soft-pill">aula guiada</span>
                <span class="app-soft-pill">currículo anual</span>
                <span class="app-soft-pill">acervo separado</span>
            </div>
        </div>

        <div class="family-hero-side">
            <div class="hero-status-card @(Model.Storage.HasPaidPlan ? "success" : string.Empty)">
                <span class="app-status @(Model.Storage.HasPaidPlan ? "success" : "neutral")">@Model.Storage.CurrentPlanName</span>
                <strong>@Model.Storage.UsedFiles de @Model.Storage.FileLimit arquivo(s)</strong>
                <p>@Model.Storage.CurrentPlanSummary</p>
                <p class="storage-helper-text">@Model.Storage.UploadNotice</p>
                <div class="hero-action-row">
                    @if (nextChild is not null)
                    {
                        <a class="btn-secondary" asp-action="Evidences" asp-route-id="@nextChild.Id">Abrir acervo</a>
                    }
                    else
                    {
                        <a class="btn-secondary" href="#storage-plans">Ver planos</a>
                    }

                    @if (Model.Storage.CanManageBilling)
                    {
                        <button class="btn-secondary" type="button" onclick="openPortal()">Gerenciar cobrança</button>
                    }
                    else
                    {
                        <button class="btn-primary" type="button" onclick="startCheckout('files_200', '', '@returnUrl')">Ampliar para 200</button>
                    }
                </div>
            </div>
        </div>
    </section>

    @if ((string?)ViewBag.Checkout == "success")
    {
        <section class="app-inline-message">
            <strong>Pagamento confirmado.</strong>
            <span>Seu plano de armazenamento está sendo atualizado no acervo da família.</span>
        </section>
    }
    else if ((string?)ViewBag.Checkout == "cancel")
    {
        <section class="app-inline-message warning">
            <strong>Checkout cancelado.</strong>
            <span>O sistema segue livre. Você só precisa voltar aqui quando quiser ampliar o acervo.</span>
        </section>
    }

    @if (billingState == "updated")
    {
        <section class="app-inline-message">
            <strong>Plano atualizado.</strong>
            <span>O limite do acervo mudou e já vale para a família.</span>
        </section>
    }
    else if (billingState == "return")
    {
        <section class="app-inline-message">
            <strong>Cobrança revisada.</strong>
            <span>Você voltou da área da Stripe e o app continua pronto para uso.</span>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <section class="app-inline-message @(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "warning" : string.Empty)">
            <strong>@(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "Atenção." : "Tudo certo.")</strong>
            <span>@statusMessage</span>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.GateMessage))
    {
        <section class="app-inline-message">
            <strong>Modelo atualizado.</strong>
            <span>@Model.GateMessage</span>
        </section>
    }

    @if (Model.Children.Count == 0)
    {
        <section class="family-empty-state">
            <article class="app-card">
                <span class="app-kicker">Primeiro passo</span>
                <h2>Cadastre a primeira criança</h2>
                <p>Com um único cadastro, o sistema já monta a rotina, o currículo anual e a primeira aula do dia. O acervo começa no gratuito e só cresce de plano se a família realmente precisar de mais espaço.</p>
                <div class="hero-action-row">
                    <a class="btn-primary" asp-action="CreateChild">Cadastrar criança</a>
                    <a class="btn-secondary" href="#storage-plans">Ver planos do acervo</a>
                </div>
            </article>
        </section>
    }
    else
    {
        <section class="family-highlight-grid family-highlight-grid-simple">
            <article class="today-child-card">
                <div class="today-child-card-top">
                    <div>
                        <span class="app-kicker">Hoje</span>
                        <h2>@(nextChild?.FullName ?? "Escolha uma criança")</h2>
                    </div>
                    <span class="app-status @(nextChild?.PlanCompletedToday == true ? "success" : "warning")">
                        @(nextChild?.PlanCompletedToday == true ? "feito hoje" : "próxima ação")
                    </span>
                </div>

                @if (nextChild is null)
                {
                    <p>Nenhuma criança encontrada.</p>
                }
                else
                {
                    <p class="today-theme">@nextChild.CurrentFocus</p>
                    <p class="today-explainer">@nextChild.WeeklyHeadline</p>
                    <div class="hero-action-row">
                        <a class="btn-primary" asp-action="Child" asp-route-id="@nextChild.Id">Abrir lições do dia</a>
                        <a class="btn-secondary" asp-action="Curriculum" asp-route-id="@nextChild.Id">Ver currículo</a>
                    </div>
                }
            </article>

            <article class="overview-card overview-card-guide">
                <span class="app-kicker">Use assim hoje</span>
                <h2>O app conduz a família em 3 passos</h2>

                <div class="simple-steps-list compact">
                    <article class="simple-step-item">
                        <strong>1. Abra a criança certa</strong>
                        <p>Comece sempre em <strong>Abrir hoje</strong>. A lição atual já sobe primeiro.</p>
                    </article>
                    <article class="simple-step-item">
                        <strong>2. Conclua uma lição por vez</strong>
                        <p>Leia o passo a passo, use o material indicado e toque em <strong>Concluir lição</strong>.</p>
                    </article>
                    <article class="simple-step-item">
                        <strong>3. Guarde só o que importa</strong>
                        <p>Fotos, vídeos e documentos ficam em <strong>Evidências</strong>, sem poluir a aula.</p>
                    </article>
                </div>

                <div class="hero-chip-row dashboard-mini-strip">
                    <span class="app-soft-pill">@Model.TotalChildren criança(s)</span>
                    <span class="app-soft-pill">@Model.MinutesThisWeek min nesta semana</span>
                    <span class="app-soft-pill">@Model.Consistency.CurrentStreakDays dia(s) seguidos</span>
                    <span class="app-soft-pill">@Model.Consistency.ConsistencyPercent% de constância</span>
                </div>

                <div class="hero-action-row">
                    <a class="btn-secondary" asp-action="Academy" asp-route-childId="@nextChild?.Id">Biblioteca certa</a>
                    <a class="btn-secondary" asp-action="Evidences" asp-route-id="@nextChild?.Id">Evidências</a>
                </div>
            </article>
        </section>
    }

    <section class="app-card" id="storage-plans">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Acervo da família</span>
                <h2>Planos de armazenamento</h2>
            </div>
            <span class="app-status neutral">@Model.Storage.CurrentPlanStatusLabel</span>
        </div>

        <div class="storage-meta-row">
            <strong>@Model.Storage.UsedFiles de @Model.Storage.FileLimit arquivo(s)</strong>
            <span>@Model.Storage.RemainingFiles restante(s)</span>
        </div>
        <div class="storage-progress-track" aria-hidden="true">
            <div class="storage-progress-fill" style="width:@Model.Storage.UsagePercent%"></div>
        </div>
        <p class="storage-helper-text">@Model.Storage.UploadNotice</p>
        <p class="storage-helper-text">@Model.Storage.UpgradeHint</p>

        <div class="storage-plan-grid">
            @foreach (var plan in Model.Storage.Plans)
            {
                var extraInputId = $"extra-{plan.PlanCode}";
                <article class="storage-plan-card @(plan.IsCurrent ? "current" : string.Empty)">
                    <span class="app-kicker">@plan.Name</span>
                    <h3>@plan.PriceLabel</h3>
                    <strong>@plan.CapacityLabel</strong>
                    <p>@plan.Description</p>

                    @if (plan.SupportsExtraBlocks)
                    {
                        <div class="storage-extra-stack">
                            <label for="@extraInputId">Acima de 5.000 arquivos</label>
                            <input id="@extraInputId"
                                   class="input"
                                   type="number"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="@(plan.IsCurrent ? Model.Storage.ExtraBlocks : 0)" />
                            <p class="storage-helper-text">@Model.Storage.ExtraBlockSummary</p>
                        </div>
                    }

                    @if (string.Equals(plan.PlanCode, "free", StringComparison.OrdinalIgnoreCase))
                    {
                        <button class="btn-secondary" type="button" disabled>Plano gratuito</button>
                    }
                    else
                    {
                        <button class="@(plan.IsCurrent ? "btn-secondary" : "btn-primary")"
                                type="button"
                                onclick="startCheckout('@plan.PlanCode', '@(plan.SupportsExtraBlocks ? extraInputId : string.Empty)', '@returnUrl')">
                            @(plan.IsCurrent && !plan.SupportsExtraBlocks ? "Plano atual" : plan.ButtonLabel)
                        </button>
                    }
                </article>
            }
        </div>

        @if (Model.Storage.CanManageBilling)
        {
            <div class="hero-action-row">
                <button class="btn-secondary" type="button" onclick="openPortal()">Gerenciar cobrança na Stripe</button>
            </div>
        }
    </section>

    @if (Model.Children.Count > 0)
    {
        <section class="child-strip-section" id="children-section">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Crianças</span>
                    <h2>Escolha quem vai estudar agora</h2>
                </div>
                <a class="btn-secondary" asp-action="CreateChild">Adicionar criança</a>
            </div>

            <div class="child-strip-grid">
                @foreach (var child in Model.Children)
                {
                    var childInitial = string.IsNullOrWhiteSpace(child.FullName)
                        ? "C"
                        : child.FullName.Trim()[0].ToString().ToUpperInvariant();
                    <article class="mini-child-card mini-child-card-actionable">
                        <span class="mini-child-avatar">@childInitial</span>
                        <div>
                            <strong>@child.FullName</strong>
                            <span>@child.Age anos • @child.DailyStudyMinutes min/dia</span>
                            <span>@child.CurrentFocus</span>
                        </div>
                        <span class="app-status @(child.PlanCompletedToday ? "success" : "neutral")">
                            @(child.PlanCompletedToday ? "feito hoje" : "próximo passo")
                        </span>
                        <div class="mini-child-actions">
                            <a class="btn-secondary" asp-action="Child" asp-route-id="@child.Id">Abrir hoje</a>
                            <a class="btn-secondary" asp-action="Curriculum" asp-route-id="@child.Id">Plano anual</a>
                            <a class="btn-secondary" asp-action="EditChild" asp-route-id="@child.Id">Editar</a>
                            <form method="post"
                                  asp-action="DeleteChild"
                                  asp-route-id="@child.Id"
                                  class="inline-action-form"
                                  onsubmit="return confirm('Tem certeza que deseja excluir esta criança e todo o histórico dela?');">
                                @Html.AntiForgeryToken()
                                <button class="btn-danger" type="submit">Excluir</button>
                            </form>
                        </div>
                    </article>
                }
            </div>
        </section>
    }
</section>

@section Scripts {
    <script>
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function readExtraBlocks(inputId) {
            if (!inputId) {
                return 0;
            }

            const input = document.getElementById(inputId);
            if (!input) {
                return 0;
            }

            const value = parseInt(input.value || '0', 10);
            return Number.isFinite(value) && value > 0 ? value : 0;
        }

        async function startCheckout(planCode, extraInputId = '', returnUrl = '@returnUrl') {
            const response = await fetch('/billing/create-checkout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify({
                    planCode,
                    extraBlocks: readExtraBlocks(extraInputId),
                    returnUrl
                })
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.error || 'Nao foi possivel iniciar a cobranca.');
                return;
            }

            if (data.url) {
                window.location.href = data.url;
                return;
            }

            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
                return;
            }

            window.location.reload();
        }

        async function openPortal() {
            const response = await fetch('/billing/create-portal-session', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getToken()
                }
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.error || 'Nao foi possivel abrir a area de cobranca.');
                return;
            }

            if (data.url) {
                window.location.href = data.url;
            }
        }
    </script>
}
