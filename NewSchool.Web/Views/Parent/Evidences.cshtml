@model NewSchool.Web.Models.ChildEvidenceCenterViewModel
@{
    ViewData["Title"] = "Evidências";
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusKind = TempData["StatusKind"]?.ToString();
    var returnUrl = Url.Action("Evidences", "Parent", new { id = Model.ChildId }) ?? $"/Parent/Evidences/{Model.ChildId}";
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" href="@Model.ChildUrl">Voltar para hoje</a>
        <div class="hero-chip-row">
            <a class="app-soft-pill" href="@Model.ChildUrl">Hoje</a>
            <a class="app-soft-pill" href="@Model.CurriculumUrl">Currículo</a>
            <span class="app-soft-pill active">Evidências</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <section class="app-inline-message @(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "warning" : string.Empty)">
            <strong>@(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "Atenção." : "Tudo certo.")</strong>
            <span>@statusMessage</span>
        </section>
    }

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">Central de evidências</span>
                <h1>@Model.FullName</h1>
                <p>@Model.Age anos • fotos, vídeos e documentos em um lugar só</p>
            </div>
            <span class="app-status success">@Model.TotalItems item(ns)</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">Guardar memória e prova</span>
                <h2>Anexos separados da aula do dia</h2>
                <p>Aqui a família salva o que quiser sem poluir a rotina de ensino: foto, vídeo, PDF e documento.</p>
            </div>
        </article>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Limite da família</span>
                <h2>@Model.Storage.CurrentPlanName</h2>
            </div>
            <span class="app-status @(Model.Storage.HasPaidPlan ? "success" : "neutral")">@Model.Storage.CurrentPlanStatusLabel</span>
        </div>

        <div class="storage-meta-row">
            <strong>@Model.Storage.UsedFiles de @Model.Storage.FileLimit arquivo(s)</strong>
            <span>@Model.Storage.RemainingFiles restante(s)</span>
        </div>
        <div class="storage-progress-track" aria-hidden="true">
            <div class="storage-progress-fill" style="width:@Model.Storage.UsagePercent%"></div>
        </div>
        <p class="storage-helper-text">@Model.Storage.UploadNotice</p>
        <p class="storage-helper-text">@Model.Storage.UpgradeHint</p>

        <div class="storage-plan-grid">
            @foreach (var plan in Model.Storage.Plans)
            {
                var extraInputId = $"extra-{plan.PlanCode}";
                <article class="storage-plan-card @(plan.IsCurrent ? "current" : string.Empty)">
                    <span class="app-kicker">@plan.Name</span>
                    <h3>@plan.PriceLabel</h3>
                    <strong>@plan.CapacityLabel</strong>
                    <p>@plan.Description</p>

                    @if (plan.SupportsExtraBlocks)
                    {
                        <div class="storage-extra-stack">
                            <label for="@extraInputId">Acima de 5.000 arquivos</label>
                            <input id="@extraInputId"
                                   class="input"
                                   type="number"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="@(plan.IsCurrent ? Model.Storage.ExtraBlocks : 0)" />
                            <p class="storage-helper-text">@Model.Storage.ExtraBlockSummary</p>
                        </div>
                    }

                    @if (string.Equals(plan.PlanCode, "free", StringComparison.OrdinalIgnoreCase))
                    {
                        <button class="btn-secondary" type="button" disabled>Plano gratuito</button>
                    }
                    else
                    {
                        <button class="@(plan.IsCurrent ? "btn-secondary" : "btn-primary")"
                                type="button"
                                onclick="startCheckout('@plan.PlanCode', '@(plan.SupportsExtraBlocks ? extraInputId : string.Empty)', '@returnUrl')">
                            @(plan.IsCurrent && !plan.SupportsExtraBlocks ? "Plano atual" : plan.ButtonLabel)
                        </button>
                    }
                </article>
            }
        </div>

        @if (Model.Storage.CanManageBilling)
        {
            <div class="hero-action-row">
                <button class="btn-secondary" type="button" onclick="openPortal()">Gerenciar cobrança na Stripe</button>
            </div>
        }
    </section>

    <section class="family-highlight-grid">
        <article class="overview-card">
            <span class="app-kicker">Fotos</span>
            <h2>@Model.PhotoCount</h2>
        </article>
        <article class="overview-card">
            <span class="app-kicker">Vídeos</span>
            <h2>@Model.VideoCount</h2>
        </article>
        <article class="overview-card">
            <span class="app-kicker">Documentos</span>
            <h2>@Model.DocumentCount</h2>
        </article>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Salvar arquivo</span>
                <h2>Novo anexo</h2>
            </div>
        </div>

        <form method="post" asp-action="UploadEvidence" enctype="multipart/form-data" class="compact-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Upload.ChildId" />
            <input type="hidden" asp-for="Upload.DailyPlanId" />
            <div>
                <label asp-for="Upload.Title"></label>
                <input class="input" asp-for="Upload.Title" placeholder="Ex.: leitura em voz alta" />
            </div>
            <div>
                <label asp-for="Upload.File"></label>
                <input class="input" asp-for="Upload.File" type="file" disabled="@(Model.Storage.CanUpload ? null : "disabled")" />
            </div>
            <div class="full-span">
                <label asp-for="Upload.Notes"></label>
                <textarea class="textarea" asp-for="Upload.Notes" rows="3" placeholder="Observação opcional"></textarea>
            </div>
            <div class="full-span">
                <p class="storage-helper-text">
                    @if (Model.Storage.CanUpload)
                    {
                        @:Você ainda pode guardar @Model.Storage.RemainingFiles arquivo(s) com o plano atual.
                    }
                    else
                    {
                        @:O limite foi atingido. Faça upgrade para voltar a enviar arquivos.
                    }
                </p>
            </div>
            <div class="form-submit-align">
                <button class="btn-primary" type="submit" disabled="@(Model.Storage.CanUpload ? null : "disabled")">Salvar evidência</button>
            </div>
        </form>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Buscar</span>
                <h2>Encontre qualquer atividade</h2>
            </div>
        </div>

        <form method="get" class="compact-form-grid">
            <input type="hidden" name="id" value="@Model.ChildId" />
            <div>
                <label for="q">Busca</label>
                <input id="q" name="q" class="input" value="@Model.SearchQuery" placeholder="Título, nota ou arquivo" />
            </div>
            <div>
                <label for="type">Tipo</label>
                <select id="type" name="type" class="input">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SelectedType) ? "selected" : null)">Tudo</option>
                    <option value="foto" selected="@(Model.SelectedType == "foto" ? "selected" : null)">Foto</option>
                    <option value="video" selected="@(Model.SelectedType == "video" ? "selected" : null)">Vídeo</option>
                    <option value="documento" selected="@(Model.SelectedType == "documento" ? "selected" : null)">Documento</option>
                </select>
            </div>
            <div class="form-submit-align">
                <button class="btn-secondary" type="submit">Filtrar</button>
            </div>
        </form>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Acervo</span>
                <h2>Anexos salvos</h2>
            </div>
            <span class="app-status neutral">@Model.TotalItems resultado(s)</span>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty-evidence-card">
                <strong>Nenhum anexo encontrado</strong>
                <p>Salve a primeira evidência ou ajuste o filtro.</p>
            </div>
        }
        else
        {
            <div class="evidence-grid-mobile">
                @foreach (var item in Model.Items)
                {
                    <article class="evidence-asset-card">
                        <a class="evidence-item-mobile" href="@item.MediaUrl" target="_blank" rel="noopener noreferrer">
                            @if (item.IsVideo)
                            {
                                <video class="evidence-media-mobile" muted preload="metadata">
                                    <source src="@item.MediaUrl" type="@item.MediaContentType" />
                                </video>
                            }
                            else if (item.IsImage)
                            {
                                <img class="evidence-media-mobile" src="@item.MediaUrl" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="evidence-document-card large">
                                    <strong>DOC</strong>
                                    <span>@item.FileName</span>
                                </div>
                            }
                        </a>

                        <div class="evidence-asset-copy">
                            <div class="section-heading-row compact">
                                <strong>@item.Title</strong>
                                <span class="app-status neutral">@item.TypeLabel</span>
                            </div>
                            <p>@item.LoggedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <p>@item.Notes</p>
                            }
                            <a class="btn-secondary" href="@item.MediaUrl" target="_blank" rel="noopener noreferrer">Abrir ou baixar</a>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</section>

@section Scripts {
    <script>
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function readExtraBlocks(inputId) {
            if (!inputId) {
                return 0;
            }

            const input = document.getElementById(inputId);
            if (!input) {
                return 0;
            }

            const value = parseInt(input.value || '0', 10);
            return Number.isFinite(value) && value > 0 ? value : 0;
        }

        async function startCheckout(planCode, extraInputId = '', returnUrl = '@returnUrl') {
            const response = await fetch('/billing/create-checkout', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify({
                    planCode,
                    extraBlocks: readExtraBlocks(extraInputId),
                    returnUrl
                })
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.error || 'Nao foi possivel iniciar a cobranca.');
                return;
            }

            if (data.url) {
                window.location.href = data.url;
                return;
            }

            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
                return;
            }

            window.location.reload();
        }

        async function openPortal() {
            const response = await fetch('/billing/create-portal-session', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getToken()
                }
            });

            const data = await response.json();
            if (!response.ok) {
                alert(data.error || 'Nao foi possivel abrir a area de cobranca.');
                return;
            }

            if (data.url) {
                window.location.href = data.url;
            }
        }
    </script>
}
