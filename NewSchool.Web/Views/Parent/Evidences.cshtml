@model NewSchool.Web.Models.ChildEvidenceCenterViewModel
@{
    ViewData["Title"] = "Evidências";
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusKind = TempData["StatusKind"]?.ToString();
    var returnUrl = Url.Action("Evidences", "Parent", new { id = Model.ChildId }) ?? $"/Parent/Evidences/{Model.ChildId}";
    var hasEvidenceItems = Model.Items.Count > 0;
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" href="@Model.ChildUrl">Voltar para hoje</a>
        <div class="hero-chip-row">
            <a class="app-soft-pill" href="@Model.ChildUrl">Hoje</a>
            <a class="app-soft-pill" href="@Model.CurriculumUrl">Currículo</a>
            <span class="app-soft-pill active">Evidências</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <section class="app-inline-message @(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "warning" : string.Empty)">
            <strong>@(string.Equals(statusKind, "warning", StringComparison.OrdinalIgnoreCase) ? "Atenção." : "Tudo certo.")</strong>
            <span>@statusMessage</span>
        </section>
    }

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">Central de evidências</span>
                <h1>@Model.FullName</h1>
                <p>@Model.Age anos • fotos, vídeos e documentos em um lugar só</p>
            </div>
            <span class="app-status success">@Model.TotalItems item(ns)</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">Guardar memória e prova</span>
                <h2>Anexos separados da aula do dia</h2>
                <p>Aqui a família salva o que quiser sem poluir a rotina de ensino: foto, vídeo, PDF e documento.</p>
            </div>
        </article>
    </section>

    <section class="family-highlight-grid">
        <article class="overview-card">
            <span class="app-kicker">Fotos</span>
            <h2>@Model.PhotoCount</h2>
        </article>
        <article class="overview-card">
            <span class="app-kicker">Vídeos</span>
            <h2>@Model.VideoCount</h2>
        </article>
        <article class="overview-card">
            <span class="app-kicker">Documentos</span>
            <h2>@Model.DocumentCount</h2>
        </article>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Salvar arquivo</span>
                <h2>Novo anexo</h2>
            </div>
        </div>

        <form id="evidence-upload-form" method="post" asp-action="UploadEvidence" enctype="multipart/form-data" class="compact-form-grid">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Upload.ChildId" />
            <input type="hidden" asp-for="Upload.DailyPlanId" />
            <div>
                <label asp-for="Upload.Title"></label>
                <input class="input" asp-for="Upload.Title" placeholder="Ex.: leitura em voz alta" />
            </div>
            <div>
                <label asp-for="Upload.File"></label>
                <input class="input"
                       asp-for="Upload.File"
                       type="file"
                       accept="image/*,video/*,.pdf,.doc,.docx"
                       disabled="@(Model.Storage.CanUpload ? null : "disabled")" />
            </div>
            <div class="full-span">
                <label asp-for="Upload.Notes"></label>
                <textarea class="textarea" asp-for="Upload.Notes" rows="3" placeholder="Observação opcional"></textarea>
            </div>
            <div class="full-span">
                <p class="storage-helper-text">
                    @if (Model.Storage.CanUpload)
                    {
                        @:Você ainda pode guardar @Model.Storage.RemainingFiles arquivo(s) no acervo da família inteira com o plano atual.
                    }
                    else
                    {
                        @:O limite do acervo da família inteira foi atingido. Faça upgrade para voltar a enviar arquivos.
                    }
                </p>
                <p class="storage-helper-text">Envie foto, vídeo ou documento com até 95 MB. Para vídeo, MP4 e MOV funcionam melhor no celular.</p>
                <p id="chunk-upload-feedback" class="storage-helper-text" hidden></p>
                <div id="chunk-upload-progress" class="storage-progress-track" hidden aria-hidden="true">
                    <div id="chunk-upload-progress-fill" class="storage-progress-fill" style="width:0%"></div>
                </div>
            </div>
            <div class="form-submit-align form-submit-align-wrap">
                <button id="evidence-upload-submit" class="btn-primary" type="submit" disabled="@(Model.Storage.CanUpload ? null : "disabled")">Salvar evidência</button>
                <a class="btn-secondary" asp-action="Plans">Ver planos</a>
            </div>
        </form>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Buscar</span>
                <h2>Encontre qualquer atividade</h2>
            </div>
        </div>

        <form method="get" class="compact-form-grid">
            <input type="hidden" name="id" value="@Model.ChildId" />
            <div>
                <label for="q">Busca</label>
                <input id="q" name="q" class="input" value="@Model.SearchQuery" placeholder="Título, nota ou arquivo" />
            </div>
            <div>
                <label for="type">Tipo</label>
                <select id="type" name="type" class="input">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SelectedType) ? "selected" : null)">Tudo</option>
                    <option value="foto" selected="@(Model.SelectedType == "foto" ? "selected" : null)">Foto</option>
                    <option value="video" selected="@(Model.SelectedType == "video" ? "selected" : null)">Vídeo</option>
                    <option value="documento" selected="@(Model.SelectedType == "documento" ? "selected" : null)">Documento</option>
                </select>
            </div>
            <div class="form-submit-align">
                <button class="btn-secondary" type="submit">Filtrar</button>
            </div>
        </form>
    </section>

    @if (hasEvidenceItems)
    {
        <div id="evidence-viewer-modal" class="evidence-viewer-modal" hidden>
            <div class="evidence-viewer-backdrop" data-evidence-modal-close="true"></div>
            <section id="evidence-viewer-panel" class="app-card evidence-viewer-panel evidence-viewer-dialog" role="dialog" aria-modal="true" aria-labelledby="evidence-viewer-title">
                <div class="section-heading-row">
                    <div>
                        <span class="app-kicker">Visualização</span>
                        <h2 id="evidence-viewer-title">Arquivo selecionado</h2>
                    </div>
                    <button id="evidence-viewer-close" class="btn-secondary evidence-viewer-close" type="button">Fechar</button>
                </div>

                <p id="evidence-viewer-meta" class="guided-lesson-parent"></p>
                <div id="evidence-viewer-stage" class="evidence-viewer-stage"></div>
                <p id="evidence-viewer-notes" class="guided-lesson-parent" hidden></p>

                <div class="evidence-viewer-actions">
                    <a id="evidence-viewer-download" class="btn-secondary" href="#" download>Baixar</a>
                    <form id="evidence-delete-form" method="post" asp-action="DeleteEvidence" class="evidence-delete-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="childId" value="@Model.ChildId" />
                        <input type="hidden" id="evidence-delete-session-id" name="sessionId" value="" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button class="btn-secondary evidence-delete-button" type="submit">Excluir</button>
                    </form>
                </div>
            </section>
        </div>
    }

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Acervo</span>
                <h2>Anexos salvos</h2>
            </div>
            <span class="app-status neutral">@Model.TotalMatchingItems resultado(s)</span>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty-evidence-card">
                <strong>@(Model.TotalItems == 0 ? "Nenhum anexo salvo ainda" : "Nenhum resultado com este filtro")</strong>
                <p>
                    @(Model.TotalItems == 0
                        ? "Esta criança ainda não tem foto, vídeo ou documento gravado no acervo. Assim que o upload terminar de verdade, o arquivo aparece aqui automaticamente."
                        : "A criança já tem arquivos no acervo, mas este filtro não encontrou nada. Ajuste a busca ou o tipo para ver os anexos certos.")
                </p>
            </div>
        }
        else
        {
            <div class="evidence-grid-mobile">
                @foreach (var item in Model.Items)
                {
                    <article class="evidence-asset-card">
                        <button type="button"
                                class="evidence-item-mobile evidence-open-button"
                                data-child-id="@item.ChildId"
                                data-session-id="@item.SessionId"
                                data-title="@item.Title"
                                data-notes="@item.Notes"
                                data-media-url="@item.MediaUrl"
                                data-media-content-type="@item.MediaContentType"
                                data-thumbnail-url="@item.ThumbnailUrl"
                                data-type-label="@item.TypeLabel"
                                data-file-name="@item.FileName"
                                data-logged-at="@item.LoggedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")">
                            @if (item.IsVideo)
                            {
                                <div class="evidence-video-thumb-shell @(item.HasThumbnail ? string.Empty : "is-pending")"
                                     data-evidence-video-thumb="true"
                                     data-generate-thumbnail="@(item.HasThumbnail ? "false" : "true")"
                                     data-video-url="@item.MediaUrl"
                                     data-video-title="@item.Title">
                                    @if (item.HasThumbnail)
                                    {
                                        <img class="evidence-media-mobile" src="@item.ThumbnailUrl" alt="@item.Title" />
                                    }
                                    else
                                    {
                                        <div class="evidence-video-thumb-fallback">
                                            <strong>Vídeo</strong>
                                            <span>Miniatura sendo preparada</span>
                                        </div>
                                    }
                                    <span class="evidence-play-badge">Assistir</span>
                                </div>
                            }
                            else if (item.IsImage)
                            {
                                <img class="evidence-media-mobile" src="@item.MediaUrl" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="evidence-document-card large">
                                    <strong>DOC</strong>
                                    <span>@item.FileName</span>
                                </div>
                            }
                        </button>

                        <div class="evidence-asset-copy">
                            <div class="section-heading-row compact">
                                <strong>@item.Title</strong>
                                <span class="app-status neutral">@item.TypeLabel</span>
                            </div>
                            <p>@item.LoggedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <p>@item.Notes</p>
                            }
                            <p class="evidence-open-helper">Toque na miniatura para abrir aqui no sistema.</p>
                        </div>
                    </article>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="evidence-pagination" aria-label="Páginas do acervo">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="btn-secondary"
                           asp-action="Evidences"
                           asp-route-id="@Model.ChildId"
                           asp-route-q="@Model.SearchQuery"
                           asp-route-type="@Model.SelectedType"
                           asp-route-page="@(Model.PageNumber - 1)">
                            Ver anteriores
                        </a>
                    }

                    <span class="app-status neutral">Página @Model.PageNumber de @Model.TotalPages</span>

                    @if (Model.HasNextPage)
                    {
                        <a class="btn-secondary"
                           asp-action="Evidences"
                           asp-route-id="@Model.ChildId"
                           asp-route-q="@Model.SearchQuery"
                           asp-route-type="@Model.SelectedType"
                           asp-route-page="@(Model.PageNumber + 1)">
                            Ver mais
                        </a>
                    }
                </nav>
            }
        }
    </section>
</section>

@section Scripts {
    <script>
        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function isProbablyVideoFile(file) {
            if (!file) {
                return false;
            }

            if ((file.type || '').startsWith('video/')) {
                return true;
            }

            const lowerName = (file.name || '').toLowerCase();
            return ['.mp4', '.mov', '.m4v', '.webm', '.3gp', '.3g2'].some((extension) => lowerName.endsWith(extension));
        }

        function onceMediaEvent(target, eventName, timeoutMs = 8000) {
            return new Promise((resolve, reject) => {
                let timeoutId = null;

                function cleanup() {
                    target.removeEventListener(eventName, handleSuccess);
                    target.removeEventListener('error', handleError);
                    if (timeoutId) {
                        window.clearTimeout(timeoutId);
                    }
                }

                function handleSuccess() {
                    cleanup();
                    resolve();
                }

                function handleError() {
                    cleanup();
                    reject(new Error('Nao foi possivel preparar este video agora.'));
                }

                target.addEventListener(eventName, handleSuccess, { once: true });
                target.addEventListener('error', handleError, { once: true });
                timeoutId = window.setTimeout(() => {
                    cleanup();
                    reject(new Error('O video demorou demais para responder.'));
                }, timeoutMs);
            });
        }

        async function seekVideoTo(video, targetTime) {
            const safeTime = Math.max(0.1, targetTime);
            if (Math.abs((video.currentTime || 0) - safeTime) < 0.05) {
                return;
            }

            const seekPromise = onceMediaEvent(video, 'seeked', 8000);
            video.currentTime = safeTime;
            await seekPromise;
        }

        function resolveThumbnailCaptureTime(duration) {
            const preferredLongVideoSeconds = 66;
            if (Number.isFinite(duration) && duration > preferredLongVideoSeconds + 1) {
                return preferredLongVideoSeconds;
            }

            if (!Number.isFinite(duration) || duration <= 0) {
                return 1.1;
            }

            if (duration > 8) {
                return Math.min(Math.max(duration * 0.2, 1.1), duration - 0.4);
            }

            return Math.max(0.1, Math.min(1.1, duration / 2));
        }

        async function captureVideoThumbnailFromSource(sourceUrl, cleanup = null) {
            const video = document.createElement('video');
            video.preload = 'metadata';
            video.muted = true;
            video.playsInline = true;
            video.src = sourceUrl;

            try {
                await onceMediaEvent(video, 'loadedmetadata', 10000);

                const duration = Number.isFinite(video.duration) ? video.duration : 0;
                const captureTime = resolveThumbnailCaptureTime(duration);
                await seekVideoTo(video, captureTime);

                const width = video.videoWidth || 720;
                const height = video.videoHeight || 405;
                if (width <= 0 || height <= 0) {
                    return '';
                }

                const canvas = document.createElement('canvas');
                canvas.width = width;
                canvas.height = height;
                const context = canvas.getContext('2d');
                if (!context) {
                    return '';
                }

                context.drawImage(video, 0, 0, width, height);
                return canvas.toDataURL('image/jpeg', 0.84);
            } catch {
                return '';
            } finally {
                if (typeof cleanup === 'function') {
                    cleanup();
                }

                video.pause();
                video.removeAttribute('src');
                video.load();
            }
        }

        async function captureVideoThumbnailFromFile(file) {
            const objectUrl = URL.createObjectURL(file);
            try {
                return await captureVideoThumbnailFromSource(objectUrl, () => URL.revokeObjectURL(objectUrl));
            } catch {
                URL.revokeObjectURL(objectUrl);
                return '';
            }
        }

        function createEvidenceViewerFallback(fileName, message) {
            const fallback = document.createElement('div');
            fallback.className = 'evidence-document-card large evidence-viewer-document-card';

            const strong = document.createElement('strong');
            strong.textContent = 'Arquivo salvo';
            fallback.appendChild(strong);

            const file = document.createElement('span');
            file.textContent = fileName || 'Arquivo da família';
            fallback.appendChild(file);

            const helper = document.createElement('p');
            helper.textContent = message || 'Se a visualização não abrir aqui, use o botão Baixar logo abaixo.';
            fallback.appendChild(helper);

            return fallback;
        }

        function inferEvidenceKind(mediaContentType, fileName, mediaUrl) {
            if ((mediaContentType || '').startsWith('video/')) {
                return 'video';
            }

            if ((mediaContentType || '').startsWith('image/')) {
                return 'image';
            }

            if ((mediaContentType || '').startsWith('application/pdf')) {
                return 'pdf';
            }

            const source = (fileName || mediaUrl || '').toLowerCase();
            if (['.mp4', '.mov', '.m4v', '.webm', '.3gp', '.3g2'].some((extension) => source.endsWith(extension))) {
                return 'video';
            }

            if (['.jpg', '.jpeg', '.png', '.webp', '.gif', '.heic', '.heif'].some((extension) => source.endsWith(extension))) {
                return 'image';
            }

            if (source.endsWith('.pdf')) {
                return 'pdf';
            }

            return 'document';
        }

        function createEvidenceViewerElement(kind, mediaUrl, mediaContentType, title, fileName, thumbnailUrl) {
            if (kind === 'video') {
                const video = document.createElement('video');
                video.className = 'evidence-viewer-media';
                video.controls = true;
                video.preload = 'metadata';
                video.playsInline = true;
                video.src = mediaUrl;
                if (thumbnailUrl) {
                    video.poster = thumbnailUrl;
                }
                video.append('Seu navegador não conseguiu reproduzir este vídeo aqui. Use o botão Baixar.');
                video.addEventListener('error', () => {
                    const replacement = createEvidenceViewerFallback(
                        fileName,
                        'Este vídeo não abriu no visualizador agora. Use Baixar para assistir no aparelho ou tente novamente em instantes.');
                    video.replaceWith(replacement);
                }, { once: true });
                return video;
            }

            if (kind === 'image') {
                const image = document.createElement('img');
                image.className = 'evidence-viewer-media';
                image.src = mediaUrl;
                image.alt = title || fileName || 'Evidência';
                return image;
            }

            if (kind === 'pdf') {
                const frame = document.createElement('iframe');
                frame.className = 'evidence-viewer-document';
                frame.src = `${mediaUrl}#view=FitH`;
                frame.title = title || fileName || 'Documento';
                return frame;
            }

            return createEvidenceViewerFallback(fileName, 'Este tipo de arquivo abre melhor pelo botão Baixar logo abaixo.');
        }

        async function persistGeneratedThumbnail(childId, sessionId, thumbnailDataUrl) {
            if (!childId || !sessionId || !thumbnailDataUrl) {
                return null;
            }

            const formData = new FormData();
            formData.append('__RequestVerificationToken', getToken());
            formData.append('ChildId', childId);
            formData.append('SessionId', sessionId);
            formData.append('ThumbnailDataUrl', thumbnailDataUrl);

            const response = await fetch('@(Url.Action("SaveEvidenceThumbnail", "Parent") ?? "/Parent/SaveEvidenceThumbnail")', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': getToken()
                },
                body: formData
            });

            if (!response.ok) {
                return null;
            }

            const payload = await response.json().catch(() => null);
            return payload?.thumbnailUrl || null;
        }

        async function hydratePendingEvidenceVideoThumbnails() {
            const pendingFrames = document.querySelectorAll('[data-evidence-video-thumb="true"][data-generate-thumbnail="true"]');
            for (const frame of pendingFrames) {
                const videoUrl = frame.getAttribute('data-video-url');
                const title = frame.getAttribute('data-video-title') || 'Miniatura do vídeo';
                const ownerButton = frame.closest('.evidence-open-button');
                const childId = ownerButton?.getAttribute('data-child-id') || '';
                const sessionId = ownerButton?.getAttribute('data-session-id') || '';
                if (!videoUrl) {
                    continue;
                }

                const thumbnailDataUrl = await captureVideoThumbnailFromSource(videoUrl);
                if (!thumbnailDataUrl) {
                    continue;
                }

                frame.innerHTML = '';
                frame.classList.remove('is-pending');

                const image = document.createElement('img');
                image.className = 'evidence-media-mobile';
                image.src = thumbnailDataUrl;
                image.alt = title;
                frame.appendChild(image);

                const persistedThumbnailUrl = await persistGeneratedThumbnail(childId, sessionId, thumbnailDataUrl);
                if (persistedThumbnailUrl && ownerButton) {
                    ownerButton.setAttribute('data-thumbnail-url', persistedThumbnailUrl);
                    frame.setAttribute('data-generate-thumbnail', 'false');
                }

                const badge = document.createElement('span');
                badge.className = 'evidence-play-badge';
                badge.textContent = 'Assistir';
                frame.appendChild(badge);
            }
        }

        const evidenceViewerModal = document.getElementById('evidence-viewer-modal');
        const evidenceViewerPanel = document.getElementById('evidence-viewer-panel');
        const evidenceViewerStage = document.getElementById('evidence-viewer-stage');
        const evidenceViewerTitle = document.getElementById('evidence-viewer-title');
        const evidenceViewerMeta = document.getElementById('evidence-viewer-meta');
        const evidenceViewerNotes = document.getElementById('evidence-viewer-notes');
        const evidenceViewerDownload = document.getElementById('evidence-viewer-download');
        const evidenceDeleteSessionInput = document.getElementById('evidence-delete-session-id');
        const evidenceDeleteForm = document.getElementById('evidence-delete-form');
        const evidenceViewerClose = document.getElementById('evidence-viewer-close');

        function closeEvidenceViewer() {
            if (!evidenceViewerModal || !evidenceViewerPanel || !evidenceViewerStage) {
                return;
            }

            const playingVideo = evidenceViewerStage.querySelector('video');
            if (playingVideo) {
                playingVideo.pause();
            }

            evidenceViewerStage.innerHTML = '';
            evidenceViewerModal.hidden = true;
            document.body.classList.remove('modal-open');
        }

        function openEvidenceViewer(button) {
            if (!evidenceViewerModal || !evidenceViewerPanel || !evidenceViewerStage || !evidenceViewerTitle || !evidenceViewerMeta || !evidenceViewerDownload || !evidenceDeleteSessionInput) {
                return;
            }

            const mediaUrl = button.getAttribute('data-media-url') || '';
            const mediaContentType = button.getAttribute('data-media-content-type') || '';
            const title = button.getAttribute('data-title') || 'Evidência';
            const notes = button.getAttribute('data-notes') || '';
            const typeLabel = button.getAttribute('data-type-label') || 'Arquivo';
            const loggedAt = button.getAttribute('data-logged-at') || '';
            const sessionId = button.getAttribute('data-session-id') || '';
            const fileName = button.getAttribute('data-file-name') || 'arquivo';
            const thumbnailUrl = button.getAttribute('data-thumbnail-url') || '';
            const kind = inferEvidenceKind(mediaContentType, fileName, mediaUrl);

            evidenceViewerStage.innerHTML = '';
            evidenceViewerStage.appendChild(createEvidenceViewerElement(kind, mediaUrl, mediaContentType, title, fileName, thumbnailUrl));

            evidenceViewerTitle.textContent = title;
            evidenceViewerMeta.textContent = `${typeLabel} • ${loggedAt}`;
            evidenceViewerDownload.href = mediaUrl;
            evidenceViewerDownload.setAttribute('download', fileName);
            evidenceDeleteSessionInput.value = sessionId;

            if (evidenceViewerNotes) {
                evidenceViewerNotes.hidden = !notes;
                evidenceViewerNotes.textContent = notes;
            }

            evidenceViewerModal.hidden = false;
            document.body.classList.add('modal-open');
        }

        document.querySelectorAll('.evidence-open-button').forEach((button) => {
            button.addEventListener('click', () => openEvidenceViewer(button));
        });

        if (evidenceViewerClose) {
            evidenceViewerClose.addEventListener('click', closeEvidenceViewer);
        }

        document.querySelectorAll('[data-evidence-modal-close="true"]').forEach((target) => {
            target.addEventListener('click', closeEvidenceViewer);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && evidenceViewerModal && !evidenceViewerModal.hidden) {
                closeEvidenceViewer();
            }
        });

        if (evidenceDeleteForm) {
            evidenceDeleteForm.addEventListener('submit', (event) => {
                if (!window.confirm('Deseja excluir esta evidência do acervo da família?')) {
                    event.preventDefault();
                }
            });
        }

        hydratePendingEvidenceVideoThumbnails();

        const evidenceUploadForm = document.getElementById('evidence-upload-form');
        if (evidenceUploadForm) {
            const chunkUploadUrl = '@(Url.Action("UploadEvidenceChunk", "Parent") ?? "/Parent/UploadEvidenceChunk")';
            const fileInput = evidenceUploadForm.querySelector('input[name="Upload.File"]');
            const titleInput = evidenceUploadForm.querySelector('input[name="Upload.Title"]');
            const notesInput = evidenceUploadForm.querySelector('textarea[name="Upload.Notes"]');
            const childIdInput = evidenceUploadForm.querySelector('input[name="Upload.ChildId"]');
            const dailyPlanInput = evidenceUploadForm.querySelector('input[name="Upload.DailyPlanId"]');
            const submitButton = document.getElementById('evidence-upload-submit');
            const feedback = document.getElementById('chunk-upload-feedback');
            const progressTrack = document.getElementById('chunk-upload-progress');
            const progressFill = document.getElementById('chunk-upload-progress-fill');
            const chunkSize = 8 * 1024 * 1024;
            const maxChunkedUploadBytes = 350 * 1024 * 1024;
            const defaultButtonText = submitButton ? submitButton.textContent : 'Salvar evidência';

            function setChunkUploadStatus(message, percent = null) {
                if (!feedback || !progressTrack || !progressFill) {
                    return;
                }

                feedback.hidden = !message;
                feedback.textContent = message || '';

                if (percent === null) {
                    progressTrack.hidden = true;
                    progressFill.style.width = '0%';
                    return;
                }

                progressTrack.hidden = false;
                progressFill.style.width = `${percent}%`;
            }

            function setUploadingState(isUploading) {
                if (!submitButton || !fileInput) {
                    return;
                }

                submitButton.disabled = isUploading;
                fileInput.disabled = isUploading;
                if (titleInput) {
                    titleInput.disabled = isUploading;
                }
                if (notesInput) {
                    notesInput.disabled = isUploading;
                }

                submitButton.textContent = isUploading ? 'Enviando arquivo...' : defaultButtonText;
            }

            evidenceUploadForm.addEventListener('submit', async (event) => {
                const file = fileInput?.files?.[0];
                if (!file || !childIdInput) {
                    return;
                }

                event.preventDefault();

                if (file.size > maxChunkedUploadBytes) {
                    setChunkUploadStatus('Esse arquivo passou de 350 MB. Envie um vídeo menor para guardar no acervo.', null);
                    return;
                }

                const totalChunks = Math.max(1, Math.ceil(file.size / chunkSize));
                const uploadId = window.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random().toString(16).slice(2)}`;

                try {
                    setUploadingState(true);
                    let thumbnailDataUrl = '';

                    if (isProbablyVideoFile(file)) {
                        setChunkUploadStatus('Preparando a miniatura do vídeo...', 0);
                        thumbnailDataUrl = await captureVideoThumbnailFromFile(file);
                    }

                    setChunkUploadStatus('Preparando o envio do arquivo...', 0);

                    for (let chunkIndex = 0; chunkIndex < totalChunks; chunkIndex += 1) {
                        const start = chunkIndex * chunkSize;
                        const end = Math.min(start + chunkSize, file.size);
                        const blob = file.slice(start, end);
                        const formData = new FormData();
                        formData.append('__RequestVerificationToken', getToken());
                        formData.append('ChildId', childIdInput.value);
                        formData.append('DailyPlanId', dailyPlanInput?.value || '');
                        formData.append('Title', titleInput?.value || '');
                        formData.append('Notes', notesInput?.value || '');
                        formData.append('UploadId', uploadId);
                        formData.append('ChunkIndex', String(chunkIndex));
                        formData.append('TotalChunks', String(totalChunks));
                        formData.append('TotalSize', String(file.size));
                        formData.append('FileName', file.name);
                        formData.append('ContentType', file.type || 'application/octet-stream');
                        if (thumbnailDataUrl && chunkIndex === totalChunks - 1) {
                            formData.append('ThumbnailDataUrl', thumbnailDataUrl);
                        }
                        formData.append('Chunk', blob, file.name);

                        const response = await fetch(chunkUploadUrl, {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': getToken()
                            },
                            body: formData
                        });

                        const data = await response.json().catch(() => ({}));
                        if (!response.ok) {
                            throw new Error(data.error || 'Nao foi possivel enviar o arquivo agora.');
                        }

                        const percent = Math.round(((chunkIndex + 1) / totalChunks) * 100);
                        setChunkUploadStatus(`Enviando arquivo... ${chunkIndex + 1} de ${totalChunks} partes concluídas.`, percent);

                        if (data.completed && data.redirectUrl) {
                            window.location.href = data.redirectUrl;
                            return;
                        }
                    }

                    setChunkUploadStatus('O sistema terminou de enviar o arquivo. Atualizando a página...', 100);
                    window.location.reload();
                } catch (error) {
                    setUploadingState(false);
                    setChunkUploadStatus(error?.message || 'O upload falhou. Tente novamente.', null);
                }
            });
        }
    </script>
}
