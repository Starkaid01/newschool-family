@using System.Linq
@model NewSchool.Web.Models.ChildCurriculumViewModel
@{
    ViewData["Title"] = "Currículo";
    var previewEntries = Model.Entries.Take(4).ToList();
    var currentPhase = Model.AnnualPlan.Phases.FirstOrDefault(phase => phase.IsCurrent)
        ?? Model.AnnualPlan.Phases.FirstOrDefault();
    var weeklyPreview = Model.WeeklyRoadmap.Days.Take(2).ToList();
    var annualReadingSpine = Model.AnnualReadingSpine;
    var monthlyReadingGoal = Model.LibraryBridge.WeeklyReading?.MonthlyGoal;
    var systemTrackMap = Model.SystemCurriculumTracks
        .GroupBy(track => track.DomainLabel)
        .ToDictionary(group => group.Key, group => group.First(), StringComparer.OrdinalIgnoreCase);
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" asp-action="Child" asp-route-id="@Model.ChildId">Voltar para hoje</a>
        <div class="hero-chip-row">
            <a class="app-soft-pill" asp-action="Child" asp-route-id="@Model.ChildId">Hoje</a>
            <span class="app-soft-pill active">Plano anual</span>
            <a class="app-soft-pill" href="@Model.EvidenceCenterUrl">Evidências</a>
            <a class="app-soft-pill" href="@Model.AcademyUrl">Biblioteca</a>
        </div>
    </div>

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">@Model.AnnualPlan.SchoolYearLabel</span>
                <h1>@Model.FullName</h1>
                <p>@Model.Age anos • @Model.FamilyGoalTrackLabel • @Model.TeachingMethodologyLabel</p>
            </div>
            <span class="app-status success">@Model.EvidenceCount prova(s)</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">@Model.AnnualPlan.CurrentPhaseLabel</span>
                <h2>@Model.AnnualPlan.CurrentPhaseTitle</h2>
                <p>@Model.AnnualPlan.Summary</p>
                <div class="hero-chip-row">
                    <span class="app-soft-pill">@Model.AnnualPlan.CurriculumBandLabel</span>
                    <span class="app-soft-pill">@Model.AnnualPlan.TotalProprietaryLessons lições proprietárias</span>
                    <span class="app-soft-pill">@Model.AnnualPlan.Subjects.Count matéria(s)</span>
                    <span class="app-soft-pill">@Model.TotalSessions registro(s)</span>
                    <span class="app-soft-pill">@Model.TotalMinutes min acumulados</span>
                </div>
            </div>
            <div class="hero-action-row">
                <a class="btn-primary" asp-action="Child" asp-route-id="@Model.ChildId">Voltar para a aula</a>
                <a class="btn-secondary" href="@Model.EvidenceCenterUrl">Abrir evidências</a>
                <a class="btn-secondary" href="@Model.PrintUrl" target="_blank" rel="noopener noreferrer">Imprimir / PDF</a>
            </div>
        </article>
    </section>

    <section class="app-card">
        <div class="hero-chip-row">
            <a class="app-soft-pill" href="#curriculum-current-phase">Agora</a>
            <a class="app-soft-pill" href="#curriculum-phases">Ano</a>
            <a class="app-soft-pill" href="#curriculum-subjects">Matérias</a>
            <a class="app-soft-pill" href="#curriculum-history">Registros</a>
        </div>
    </section>

    <section class="family-highlight-grid family-highlight-grid-simple">
        <article class="overview-card">
            <span class="app-kicker">Etapa atual</span>
            <h2>@Model.AnnualPlan.CurrentPhaseTitle</h2>
            <p>@Model.AnnualPlan.CurrentPhaseSummary</p>
        </article>

        <article class="overview-card">
            <span class="app-kicker">Ritmo da família</span>
            <h2>Rotina clara</h2>
            <p>@Model.AnnualPlan.FamilyRoutineNote</p>
        </article>

        <article class="overview-card">
            <span class="app-kicker">Registros</span>
            <h2>@Model.EvidenceCount evidência(s)</h2>
            <p>Fotos, vídeos e documentos seguem separados da aula e prontos para consulta.</p>
        </article>
    </section>

    @if (currentPhase is not null)
    {
        <section class="app-card" id="curriculum-current-phase">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Agora</span>
                    <h2>O que esta etapa quer construir</h2>
                </div>
                <span class="app-status success">@currentPhase.MonthsLabel</span>
            </div>

            <div class="details-grid">
                <article class="child-card-note">
                    <strong>O que o adulto faz</strong>
                    <p>@currentPhase.ParentAction</p>
                </article>

                <article class="child-card-note">
                    <strong>O que a criança constrói</strong>
                    <p>@currentPhase.ChildGain</p>
                </article>

                <article class="child-card-note">
                    <strong>Como saber que avançou</strong>
                    <p>@currentPhase.CompletionSignal</p>
                </article>
            </div>
        </section>
    }

    @if (Model.WeeklyRoadmap.SubjectRuns.Count > 0)
    {
        <section class="app-card" id="curriculum-weekly-runs">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Sequência semanal e mensal</span>
                    <h2>Como cada matéria avança sem repetir o mesmo bloco</h2>
                </div>
                <span class="app-status neutral">@Model.WeeklyRoadmap.SubjectRuns.Count trilha(s)</span>
            </div>

            <div class="annual-phase-stack">
                @foreach (var run in Model.WeeklyRoadmap.SubjectRuns)
                {
                    <details class="annual-phase-details">
                        <summary class="annual-phase-summary">
                            <div>
                                <span class="app-kicker">@run.SubjectLabel</span>
                                <h3>@run.CurrentUnitLabel • @run.CurrentUnitTitle</h3>
                                <p>@run.WeekHeadline</p>
                            </div>
                            <span class="app-status @run.SubjectChipClass">semana @run.CurrentWeekStepNumber/5</span>
                        </summary>

                        <div class="annual-phase-body">
                            <article class="child-card-note">
                                <strong>Caminho desta semana</strong>
                                <div class="simple-steps-list compact">
                                    @for (var i = 0; i < run.WeekSteps.Count; i++)
                                    {
                                        <article class="simple-step-item">
                                            <strong>Dia @(i + 1)</strong>
                                            <p>@run.WeekSteps[i]</p>
                                        </article>
                                    }
                                </div>
                            </article>

                            <article class="child-card-note">
                                <strong>Caminho deste mês</strong>
                                <div class="simple-steps-list compact">
                                    @for (var i = 0; i < run.MonthSteps.Count; i++)
                                    {
                                        <article class="simple-step-item">
                                            <strong>Semana @(i + 1)</strong>
                                            <p>@run.MonthSteps[i]</p>
                                        </article>
                                    }
                                </div>
                            </article>

                            <article class="child-card-note">
                                <strong>Quando esta matéria pode seguir</strong>
                                <p>@run.CompletionSignal</p>
                            </article>
                        </div>
                    </details>
                }
            </div>
        </section>
    }

    @if (annualReadingSpine.Phases.Count > 0)
    {
        <section class="app-card" id="curriculum-reading-spine">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Leitura do ano</span>
                    <h2>@annualReadingSpine.Headline</h2>
                </div>
                <span class="app-status success">@annualReadingSpine.CurrentPhaseLabel</span>
            </div>

            <p>@annualReadingSpine.Summary</p>
            <div class="hero-chip-row">
                <span class="app-soft-pill">@annualReadingSpine.CompletedReadingsLabel</span>
            </div>

            @if (monthlyReadingGoal is not null)
            {
                <article class="child-card-note">
                    <strong>@monthlyReadingGoal.Headline</strong>
                    <p>@monthlyReadingGoal.Summary</p>
                    <div class="hero-chip-row">
                        <span class="app-soft-pill">@monthlyReadingGoal.ProgressLabel</span>
                    </div>
                    <p>@monthlyReadingGoal.AutoCloseProjectionLabel</p>

                    @if (monthlyReadingGoal.WeeklySequence.Count > 0)
                    {
                        <details class="micro-sequence-details">
                            <summary>Ver sequência de literatura do mês</summary>
                            <div class="phase-sequence-list">
                                @foreach (var item in monthlyReadingGoal.WeeklySequence)
                                {
                                    <article class="phase-sequence-item @(item.IsCurrent ? "is-current" : string.Empty)">
                                        <div class="section-heading-row compact">
                                            <strong>@item.WeekLabel</strong>
                                            <span class="app-status @(item.IsCompleted ? "success" : item.IsCurrent ? "warning" : "neutral")">@item.StatusLabel</span>
                                        </div>
                                        <p><strong>@item.Title</strong></p>
                                        <p>@item.Summary</p>
                                    </article>
                                }
                            </div>
                        </details>
                    }
                </article>
            }

            <div class="annual-phase-stack">
                @foreach (var phase in annualReadingSpine.Phases)
                {
                    <details class="annual-phase-details @(phase.IsCurrent ? "is-current" : string.Empty)" @(phase.IsCurrent ? "open" : null)>
                        <summary class="annual-phase-summary">
                            <div>
                                <span class="app-kicker">@phase.PhaseLabel</span>
                                <h3>@phase.Title</h3>
                                <p>@phase.Summary</p>
                            </div>
                            <span class="app-status @(phase.IsCurrent ? "success" : "neutral")">
                                @(phase.IsCurrent ? "agora" : "depois")
                            </span>
                        </summary>

                        <div class="annual-phase-body">
                            <div class="details-grid">
                                <article class="child-card-note">
                                    <strong>Ritmo sugerido</strong>
                                    <p>@phase.WeeklyRhythm</p>
                                </article>

                                <article class="child-card-note">
                                    <strong>Como conduzir</strong>
                                    <p>@phase.ParentGuide</p>
                                </article>

                                <article class="child-card-note">
                                    <strong>Quando seguir adiante</strong>
                                    <p>@phase.CompletionSignal</p>
                                </article>
                            </div>

                            <article class="child-card-note">
                                <strong>Literatura já concluída nesta etapa</strong>
                                <p>@phase.CompletedCountLabel</p>
                                <p>@phase.AutoCloseLabel</p>

                                @if (phase.CompletedItems.Count == 0)
                                {
                                    <p>As leituras marcadas pela família entram aqui para mostrar o que já foi vivido nesta fase do ano.</p>
                                }
                                else
                                {
                                    <div class="simple-steps-list compact">
                                        @foreach (var item in phase.CompletedItems)
                                        {
                                            <article class="simple-step-item">
                                                <strong>@item.Title</strong>
                                                <p>@item.CompletedAtLabel</p>
                                                @if (!string.IsNullOrWhiteSpace(item.GoalLabel))
                                                {
                                                    <p>@item.GoalLabel</p>
                                                }
                                            </article>
                                        }
                                    </div>
                                }
                            </article>

                            @if (phase.UnitSequences.Count > 0)
                            {
                                <details class="micro-sequence-details" @(phase.IsCurrent ? "open" : null)>
                                    <summary>Ver unidades desta etapa</summary>
                                    <div class="phase-sequence-list">
                                        @foreach (var unit in phase.UnitSequences)
                                        {
                                            <article class="phase-sequence-item @(unit.IsCurrent ? "is-current" : string.Empty)">
                                                <div class="section-heading-row compact">
                                                    <strong>@unit.UnitLabel</strong>
                                                    <span class="app-status @(unit.IsCurrent ? "warning" : "neutral")">
                                                        @(unit.IsCurrent ? "agora" : "depois")
                                                    </span>
                                                </div>
                                                <p><strong>@unit.Title</strong></p>
                                                <p>@unit.Summary</p>
                                                <p><strong>Tarefa escrita curta:</strong> @unit.WritingTaskTitle</p>
                                                <p>@unit.WritingTaskPrompt</p>
                                                <p><strong>Quando considerar pronta:</strong> @unit.WritingCompletionSignal</p>
                                                <p><strong>Evidência opcional:</strong> @unit.OptionalEvidencePrompt</p>

                                                @if (unit.UnitFlow.Count > 0)
                                                {
                                                    <div class="simple-steps-list compact">
                                                        @for (var i = 0; i < unit.UnitFlow.Count; i++)
                                                        {
                                                            <article class="simple-step-item">
                                                                <strong>Etapa @(i + 1)</strong>
                                                                <p>@unit.UnitFlow[i]</p>
                                                            </article>
                                                        }
                                                    </div>
                                                }

                                                @if (unit.Book is not null || unit.Printable is not null)
                                                {
                                                    <div class="guided-lesson-links">
                                                        @if (unit.Book is not null)
                                                        {
                                                            <a class="btn-secondary" href="@unit.Book.AccessUrl">@unit.Book.AccessLabel</a>
                                                        }
                                                        @if (unit.Printable is not null)
                                                        {
                                                            <a class="btn-secondary" href="@unit.Printable.AccessUrl">@unit.Printable.AccessLabel</a>
                                                        }
                                                    </div>
                                                }
                                            </article>
                                        }
                                    </div>
                                </details>
                            }

                            @if (phase.Book is not null || phase.Printable is not null)
                            {
                                <div class="guided-lesson-meta-grid">
                                    @if (phase.Book is not null)
                                    {
                                        <article class="child-card-note nested-surface">
                                            <strong>Livro central da etapa</strong>
                                            <p><strong>@phase.Book.Title</strong></p>
                                            <p>@phase.Book.FitReason</p>
                                            <a class="btn-secondary" href="@phase.Book.AccessUrl">@phase.Book.AccessLabel</a>
                                        </article>
                                    }

                                    @if (phase.Printable is not null)
                                    {
                                        <article class="child-card-note nested-surface">
                                            <strong>Folha de apoio da etapa</strong>
                                            <p><strong>@phase.Printable.Title</strong></p>
                                            <p>@phase.Printable.FitReason</p>
                                            <a class="btn-secondary" href="@phase.Printable.AccessUrl">@phase.Printable.AccessLabel</a>
                                        </article>
                                    }
                                </div>
                            }
                        </div>
                    </details>
                }
            </div>
        </section>
    }

    <section class="app-card" id="curriculum-phases">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Ano em 4 etapas</span>
                <h2>Sem esconder o que vem pela frente</h2>
            </div>
            <span class="app-status neutral">@Model.AnnualPlan.Phases.Count etapa(s)</span>
        </div>

        <div class="annual-phase-stack">
            @foreach (var phase in Model.AnnualPlan.Phases)
            {
                <details class="annual-phase-details @(phase.IsCurrent ? "is-current" : string.Empty)" @(phase.IsCurrent ? "open" : null)>
                    <summary class="annual-phase-summary">
                        <div>
                            <span class="app-kicker">@phase.PhaseLabel • @phase.MonthsLabel</span>
                            <h3>@phase.Title</h3>
                            <p>@phase.Summary</p>
                        </div>
                        <span class="app-status @(phase.IsCurrent ? "success" : "neutral")">
                            @(phase.IsCurrent ? phase.LessonCountLabel : phase.LessonCountLabel)
                        </span>
                    </summary>

                    <div class="annual-phase-body">
                        <div class="hero-chip-row">
                            <span class="app-soft-pill">@phase.UnitCount unidade(s)</span>
                            <span class="app-soft-pill">@phase.LessonCountLabel</span>
                        </div>

                        <div class="details-grid">
                            <article class="child-card-note">
                                <strong>Objetivo da etapa</strong>
                                <p>@phase.ChildGain</p>
                            </article>

                            <article class="child-card-note">
                                <strong>Como conduzir em casa</strong>
                                <p>@phase.ParentAction</p>
                            </article>

                            <article class="child-card-note">
                                <strong>Sinal de avanço</strong>
                                <p>@phase.CompletionSignal</p>
                            </article>
                        </div>

                        @if (phase.FeaturedTasks.Count > 0 || phase.MaterialsToKeepReady.Count > 0)
                        {
                            <div class="details-grid">
                                @if (phase.FeaturedTasks.Count > 0)
                                {
                                    <article class="app-card nested-surface">
                                        <span class="app-kicker">Exemplos de tarefas</span>
                                        <div class="simple-steps-list compact">
                                            @foreach (var task in phase.FeaturedTasks)
                                            {
                                                <article class="simple-step-item">
                                                    <p>@task</p>
                                                </article>
                                            }
                                        </div>
                                    </article>
                                }

                                @if (phase.MaterialsToKeepReady.Count > 0)
                                {
                                    <article class="app-card nested-surface">
                                        <span class="app-kicker">Materiais para deixar por perto</span>
                                        <div class="achievement-chip-row">
                                            @foreach (var item in phase.MaterialsToKeepReady)
                                            {
                                                <span class="app-soft-pill">@item</span>
                                            }
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </div>
                </details>
            }
        </div>
    </section>

    <section class="app-card" id="curriculum-subjects">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Matérias do ano</span>
                <h2>Progresso sem excesso de gráfico</h2>
            </div>
            <span class="app-status neutral">@Model.AnnualPlan.Subjects.Count área(s)</span>
        </div>

        <div class="curriculum-subject-grid">
            @foreach (var subject in Model.AnnualPlan.Subjects)
            {
                systemTrackMap.TryGetValue(subject.Title, out var systemTrack);
                <article class="curriculum-subject-card">
                    <div class="child-dashboard-top">
                        <div>
                            <h3>@subject.Title</h3>
                            <p>@subject.CurrentGoal</p>
                        </div>
                        <span class="app-status @subject.ProgressChipClass">@subject.ProgressLabel</span>
                    </div>

                    <div class="progress-line-card compact">
                        <div class="progress-line-head">
                            <span>Progresso visível</span>
                            <strong>@subject.ProgressPercent%</strong>
                        </div>
                        <div class="progress-track">
                            <span class="progress-fill teal" style="width:@Math.Clamp(subject.ProgressPercent, 0, 100)%"></span>
                        </div>
                    </div>

                    <article class="child-card-note">
                        <strong>Objetivo do ano</strong>
                        <p>@subject.YearGoal</p>
                    </article>

                    @if (systemTrack?.CurrentUnit is not null)
                    {
                        <article class="child-card-note">
                            <strong>Unidade que vale agora</strong>
                            <p><strong>@systemTrack.CurrentUnit.UnitLabel • @systemTrack.CurrentUnit.Title</strong></p>
                            <p>@systemTrack.CurrentUnit.Summary</p>
                        </article>

                        <div class="guided-lesson-meta-grid">
                            <article class="child-card-note nested-surface">
                                <strong>Tarefa principal da unidade</strong>
                                <p>@systemTrack.CurrentUnit.TaskPrompt</p>
                            </article>

                            <article class="child-card-note nested-surface">
                                <strong>Quando seguir para a próxima</strong>
                                <p>@systemTrack.CurrentUnit.CompletionSignal</p>
                            </article>
                        </div>

                        @if (systemTrack.CurrentUnit.Materials.Count > 0)
                        {
                            <article class="child-card-note">
                                <strong>Com o que ensinar nesta unidade</strong>
                                <div class="achievement-chip-row">
                                    @foreach (var material in systemTrack.CurrentUnit.Materials)
                                    {
                                        <span class="app-soft-pill">@material</span>
                                    }
                                </div>
                            </article>
                        }
                    }

                    @if (subject.RecommendedBook is not null || subject.RecommendedPrintable is not null)
                    {
                        <article class="child-card-note">
                            <strong>Material certo desta matéria</strong>
                            <div class="simple-steps-list compact">
                                @if (subject.RecommendedBook is not null)
                                {
                                    <article class="simple-step-item">
                                        <p><strong>Livro:</strong> @subject.RecommendedBook.Title</p>
                                        <p>@subject.RecommendedBook.FitReason</p>
                                        <a class="btn-secondary" href="@subject.RecommendedBook.AccessUrl">@subject.RecommendedBook.AccessLabel</a>
                                    </article>
                                }
                                @if (subject.RecommendedPrintable is not null)
                                {
                                    <article class="simple-step-item">
                                        <p><strong>Atividade:</strong> @subject.RecommendedPrintable.Title</p>
                                        <p>@subject.RecommendedPrintable.FitReason</p>
                                        <a class="btn-secondary" href="@subject.RecommendedPrintable.AccessUrl">@subject.RecommendedPrintable.AccessLabel</a>
                                    </article>
                                }
                            </div>
                        </article>
                    }

                    @if (subject.Milestones.Count > 0)
                    {
                        <article class="child-card-note">
                            <strong>Marcos que entram no caminho</strong>
                            <div class="simple-steps-list compact">
                                @foreach (var milestone in subject.Milestones)
                                {
                                    <article class="simple-step-item">
                                        <p>@milestone</p>
                                    </article>
                                }
                            </div>
                        </article>
                    }

                    @if (systemTrack is not null && systemTrack.PhaseSequences.Count > 0)
                    {
                        <details class="micro-sequence-details">
                            <summary>Ver sequência completa desta matéria</summary>
                            <div class="phase-sequence-list">
                                @foreach (var phase in systemTrack.PhaseSequences)
                                {
                                    <article class="phase-sequence-item @(phase.IsCurrent ? "is-current" : string.Empty)">
                                        <div class="section-heading-row compact">
                                            <strong>@phase.PhaseLabel</strong>
                                            <span class="app-status @(phase.IsCurrent ? "success" : "neutral")">
                                                @(phase.IsCurrent ? "agora" : "depois")
                                            </span>
                                        </div>
                                        <div class="hero-chip-row">
                                            <span class="app-soft-pill">@phase.UnitCount unidade(s)</span>
                                            <span class="app-soft-pill">@phase.LessonCount lição(ões)</span>
                                        </div>
                                        <p>@phase.Summary</p>

                                        @if (phase.Units.Count > 0)
                                        {
                                            <div class="simple-steps-list compact">
                                                @foreach (var unit in phase.Units)
                                                {
                                                    <article class="simple-step-item">
                                                        <strong>@unit.UnitLabel • @unit.Title</strong>
                                                        <p>@unit.Summary</p>
                                                        <p><strong>Tarefa:</strong> @unit.TaskPrompt</p>
                                                        <p><strong>Sinal de avanço:</strong> @unit.CompletionSignal</p>
                                                    </article>
                                                }
                                            </div>
                                        }
                                    </article>
                                }
                            </div>
                        </details>
                    }
                </article>
            }
        </div>
    </section>

    @if (weeklyPreview.Count > 0)
    {
        <details class="annual-phase-details">
            <summary class="annual-phase-summary">
                <div>
                    <span class="app-kicker">Ligação com a semana</span>
                    <h2>O plano anual já desce para a rotina</h2>
                </div>
                <span class="app-status neutral">@Model.WeeklyRoadmap.TotalMinutes min/semana</span>
            </summary>

            <div class="annual-phase-body">
                <div class="weekly-mini-list">
                    @foreach (var day in weeklyPreview)
                    {
                        <article class="weekly-mini-card @(day.RelativeLabel == "Hoje" ? "is-today" : string.Empty)">
                            <div class="section-heading-row compact">
                                <strong>@day.RelativeLabel</strong>
                                <span class="app-status @day.FocusAreaChipClass">@day.DateLabel</span>
                            </div>
                            <p><strong>@(day.TopTasks.FirstOrDefault() ?? day.Theme)</strong></p>
                            <p>@day.Summary</p>
                        </article>
                    }
                </div>
            </div>
        </details>
    }

    <details class="annual-phase-details" id="curriculum-history">
        <summary class="annual-phase-summary">
            <div>
                <span class="app-kicker">Histórico recente</span>
                <h2>O que já ficou registrado</h2>
            </div>
            <span class="app-status neutral">@Model.Entries.Count registro(s)</span>
        </summary>

        <div class="annual-phase-body">
            @if (previewEntries.Count == 0)
            {
                <div class="empty-evidence-card">
                    <strong>Nenhum registro ainda</strong>
                    <p>As entradas aparecem aqui conforme a família conclui lições e salva evidências.</p>
                </div>
            }
            else
            {
                <div class="curriculum-entry-grid">
                    @foreach (var entry in previewEntries)
                    {
                        <article class="lesson-block-card">
                            <div class="lesson-block-top">
                                <div>
                                    <h3>@entry.Theme</h3>
                                    <p>@entry.LoggedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm") • @entry.MinutesCompleted min</p>
                                </div>
                                <span class="app-soft-pill">@entry.Skills.FirstOrDefault()?.DomainLabel</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(entry.Wins))
                            {
                                <p><strong>O que avançou:</strong> @entry.Wins</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(entry.Notes))
                            {
                                <p><strong>Observação:</strong> @entry.Notes</p>
                            }
                            @if (entry.HasMedia)
                            {
                                <a class="btn-secondary" href="@entry.MediaUrl" target="_blank" rel="noopener noreferrer">Abrir evidência</a>
                            }
                        </article>
                    }
                </div>
            }
        </div>
    </details>
</section>
