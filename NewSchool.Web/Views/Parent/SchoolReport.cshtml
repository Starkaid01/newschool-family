@using System.Linq
@model NewSchool.Web.Models.ChildSchoolReportViewModel
@{
    ViewData["Title"] = "Relatório escolar";
    var currentPhaseClosures = Model.PhaseClosures.Where(item => item.IsCurrentPhase).ToList();
    var groupedClosures = Model.PhaseClosures
        .GroupBy(item => new { item.PhaseNumber, item.PhaseLabel })
        .OrderBy(group => group.Key.PhaseNumber)
        .ToList();
}

<section class="child-app-shell child-app-shell-simple">
    <div class="child-topbar-row">
        <a class="back-inline-link" href="@Model.CurriculumUrl">Voltar para currículo</a>
        <span class="app-status neutral">Relatório escolar</span>
    </div>

    <section class="child-hero-card child-hero-card-simple">
        <div class="child-identity-row">
            <div class="child-identity-copy">
                <span class="app-kicker">Documento escolar</span>
                <h1>@Model.FullName</h1>
                <p>@Model.SchoolPlacementLabel • @Model.SchoolYearLabel • @Model.GeneratedAtLabel</p>
            </div>
            <span class="app-status @Model.CurrentPhaseStatusChipClass">@Model.CurrentPhaseStatusLabel</span>
        </div>

        <article class="lesson-hero-card lesson-hero-card-simple">
            <div class="lesson-hero-copy">
                <span class="app-kicker">Etapa atual</span>
                <h2>@Model.CurrentPhaseLabel • @Model.CurrentPhaseTitle</h2>
                <p>@Model.Summary</p>
                <div class="hero-chip-row">
                    <span class="app-soft-pill">@Model.OverallProgressPercent% de progresso médio</span>
                    <span class="app-soft-pill">@Model.SessionsThisYear sessão(ões)</span>
                    <span class="app-soft-pill">@Model.EvidenceCountThisYear evidência(s)</span>
                </div>
            </div>

            <div class="hero-action-row">
                <a class="btn-primary" href="@Model.CurriculumUrl">Voltar para currículo</a>
                <a class="btn-secondary" href="@Model.ReinforcementUrl">Ver reforço</a>
                <button class="btn-secondary" type="button" onclick="window.print()">Imprimir / PDF</button>
            </div>
        </article>
    </section>

    <section class="family-highlight-grid family-highlight-grid-simple">
        <article class="overview-card">
            <span class="app-kicker">Frequência do ano</span>
            <h2>@Model.SessionsThisYear sessões</h2>
            <p>@Model.MinutesThisYear minutos registrados na jornada deste ano letivo.</p>
        </article>

        <article class="overview-card">
            <span class="app-kicker">Etapa</span>
            <h2>@Model.CurrentPhaseStatusLabel</h2>
            <p>@Model.CurrentPhaseSummary</p>
        </article>

        <article class="overview-card">
            <span class="app-kicker">Trilha da família</span>
            <h2>@Model.FamilyGoalTrackLabel</h2>
            <p>O relatório cruza a trilha da família com matérias, prova da etapa e documentação já guardada.</p>
        </article>
    </section>

    <section class="app-card">
        <div class="section-heading-row">
            <div>
                <span class="app-kicker">Matérias</span>
                <h2>Leitura formal do ano por área</h2>
            </div>
            <span class="app-status neutral">@Model.Subjects.Count matéria(s)</span>
        </div>

        <div class="curriculum-subject-grid">
            @foreach (var subject in Model.Subjects)
            {
                <article class="curriculum-subject-card">
                    <div class="child-dashboard-top">
                        <div>
                            <h3>@subject.SubjectLabel</h3>
                            <p>@subject.CurrentUnitTitle</p>
                        </div>
                        <span class="app-status @subject.PhaseStatusChipClass">@subject.PhaseStatusLabel</span>
                    </div>

                    <div class="progress-line-card compact">
                        <div class="progress-line-head">
                            <span>@subject.LessonsProgressLabel</span>
                            <strong>@subject.ProgressPercent%</strong>
                        </div>
                        <div class="progress-track">
                            <span class="progress-fill teal" style="width:@Math.Clamp(subject.ProgressPercent, 0, 100)%"></span>
                        </div>
                    </div>

                    <article class="child-card-note">
                        <strong>Objetivo do ano</strong>
                        <p>@subject.YearGoal</p>
                    </article>

                    <article class="child-card-note nested-surface">
                        <strong>Prova da etapa</strong>
                        <p>@subject.AssessmentTitle</p>
                    </article>

                    <article class="child-card-note nested-surface">
                        <strong>Notas lançadas</strong>
                        <p>@subject.AssessmentAverageLabel</p>
                        @if (subject.AssessmentCount > 0)
                        {
                            <p>@subject.AssessmentCount teste(s) corrigido(s)</p>
                        }
                        @if (subject.NeedsReinforcement)
                        {
                            <p>Essa matéria já pede reforço antes de seguir no mesmo ritmo.</p>
                        }
                    </article>

                    <article class="child-card-note nested-surface">
                        <strong>Revisão principal</strong>
                        <p>@subject.ReviewSummary</p>
                    </article>

                    <article class="child-card-note nested-surface">
                        <strong>Sinal de passagem</strong>
                        <p>@subject.AdvancementSignal</p>
                    </article>
                </article>
            }
        </div>
    </section>

    @if (currentPhaseClosures.Count > 0)
    {
        <section class="app-card">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Fechamento atual</span>
                    <h2>O que precisa fechar nesta etapa</h2>
                </div>
                <span class="app-status success">@currentPhaseClosures.Count área(s)</span>
            </div>

            <div class="curriculum-subject-grid">
                @foreach (var closure in currentPhaseClosures)
                {
                    <article class="curriculum-subject-card">
                        <div class="child-dashboard-top">
                            <div>
                                <h3>@closure.SubjectLabel</h3>
                                <p>@closure.UnitTitle</p>
                            </div>
                            <span class="app-status @closure.StatusChipClass">@closure.StatusLabel</span>
                        </div>

                        <article class="child-card-note">
                            <strong>@closure.ReviewHeadline</strong>
                            <p>@closure.ReviewSummary</p>
                        </article>

                        <article class="child-card-note nested-surface">
                            <strong>Prova da etapa</strong>
                            <p>@closure.AssessmentTitle</p>
                        </article>

                        <article class="child-card-note nested-surface">
                            <strong>Fechamento</strong>
                            <p>@closure.ClosureSummary</p>
                        </article>
                    </article>
                }
            </div>
        </section>
    }

    <details class="annual-phase-details">
        <summary class="annual-phase-summary">
            <div>
                <span class="app-kicker">Histórico por etapa</span>
                <h2>Fechamento do ano inteiro por fase</h2>
            </div>
            <span class="app-status neutral">@groupedClosures.Count etapa(s)</span>
        </summary>

        <div class="annual-phase-body">
            <div class="annual-phase-stack">
                @foreach (var group in groupedClosures)
                {
                    <article class="phase-sequence-item @(group.Any(item => item.IsCurrentPhase) ? "is-current" : string.Empty)">
                        <div class="section-heading-row compact">
                            <strong>@group.Key.PhaseLabel</strong>
                            <span class="app-status @(group.Any(item => item.IsCurrentPhase) ? "success" : "neutral")">
                                @(group.Any(item => item.IsCurrentPhase) ? "agora" : "histórico")
                            </span>
                        </div>

                        <div class="simple-steps-list compact">
                            @foreach (var closure in group)
                            {
                                <article class="simple-step-item">
                                    <strong>@closure.SubjectLabel • @closure.StatusLabel</strong>
                                    <p>@closure.LessonsProgressLabel</p>
                                    <p>@closure.AssessmentTitle</p>
                                </article>
                            }
                        </div>
                    </article>
                }
            </div>
        </div>
    </details>

    @if (Model.MonthlyHistory.Count > 0)
    {
        <details class="annual-phase-details">
            <summary class="annual-phase-summary">
                <div>
                    <span class="app-kicker">Histórico mensal</span>
                    <h2>Linha de progresso já registrada</h2>
                </div>
                <span class="app-status neutral">@Model.MonthlyHistory.Count mês(es)</span>
            </summary>

            <div class="annual-phase-body">
                <div class="curriculum-entry-grid">
                    @foreach (var month in Model.MonthlyHistory)
                    {
                        <article class="lesson-block-card">
                            <div class="lesson-block-top">
                                <div>
                                    <h3>@month.MonthLabel</h3>
                                    <p>@month.SessionsCount sessão(ões)</p>
                                </div>
                                <span class="app-soft-pill">@month.OverallScore%</span>
                            </div>
                            <p><strong>Ponto forte:</strong> @month.StrongestArea</p>
                            <p><strong>Atenção:</strong> @month.AttentionArea</p>
                            <p>@month.Summary</p>
                        </article>
                    }
                </div>
            </div>
        </details>
    }

    @if (Model.NextActions.Count > 0)
    {
        <section class="app-card">
            <div class="section-heading-row">
                <div>
                    <span class="app-kicker">Próximas ações</span>
                    <h2>O que o adulto faz depois deste relatório</h2>
                </div>
            </div>

            <div class="simple-steps-list compact">
                @foreach (var action in Model.NextActions)
                {
                    <article class="simple-step-item">
                        <p>@action</p>
                    </article>
                }
            </div>
        </section>
    }
</section>
